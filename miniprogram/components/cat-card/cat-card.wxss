/* 猫咪卡片组件样式：用于列表页复用的通用帖子卡片 */
.cat-card {
  background-color: #ffffff;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 6rpx 20rpx rgba(255, 154, 106, 0.15);
  margin-bottom: 24rpx;
}

/* 按下反馈：给整张卡片一个轻微缩放。 */
.cat-card:active {
  opacity: 0.92;
  transform: scale(0.99);
  transition: all 0.15s ease;
}

/* 图片容器：负责裁切封面图并容纳叠加元素。 */
.card-image-wrapper {
  position: relative;
  width: 100%;
  height: 380rpx;
}

/* 封面图本体。 */
.card-image {
  width: 100%;
  height: 380rpx;
}

/* 底部渐隐遮罩，方便地点标签压在图片上。 */
.image-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 100rpx;
  background: linear-gradient(to top, rgba(0, 0, 0, 0.2), transparent);
}

/* 地点标签。 */
.location-badge {
  position: absolute;
  bottom: 16rpx;
  left: 16rpx;
  background-color: rgba(0, 0, 0, 0.45);
  color: #ffffff;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  backdrop-filter: blur(4rpx);
}

/* 信息区容器。 */
.card-info {
  padding: 24rpx;
}

/* 标题行：左边名字，右边类目。 */
.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

/* 猫咪名称。 */
.cat-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #4a4a4a;
}

/* 类目标签。 */
.category-badge {
  padding: 6rpx 18rpx;
  border-radius: 16rpx;
  font-size: 20rpx;
  font-weight: bold;
}

.category-badge.stray {
  background-color: #e8f5e9;
  color: #4caf50;
}

.category-badge.pet {
  background-color: #e3f2fd;
  color: #2196f3;
}

.category-badge.lost {
  background-color: #fff3e0;
  color: #ff9800;
}

/* 摘要文本：最多两行。 */
.card-desc {
  font-size: 26rpx;
  color: #666666;
  line-height: 1.6;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  margin-bottom: 16rpx;
}

/* 底部互动栏。 */
.card-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 16rpx;
  border-top: 1rpx solid #f5f5f5;
}

/* 左侧互动按钮组。 */
.footer-left {
  display: flex;
  gap: 32rpx;
}

/* 单个互动按钮。 */
.action-btn {
  display: flex;
  align-items: center;
  gap: 6rpx;
}

/* 点赞图标。 */
.like-icon {
  font-size: 32rpx;
  line-height: 1;
  display: inline-flex;
  align-items: center;
}

.like-icon.liked {
  animation: likeAnim 0.3s ease;
}

/* 点赞放大动画。 */
@keyframes likeAnim {
  0% {
    transform: scale(1);
  }
  50% {
    transform: scale(1.3);
  }
  100% {
    transform: scale(1);
  }
}

/* 点赞数量。 */
.like-count {
  font-size: 24rpx;
  color: #999999;
  line-height: 1;
  display: inline-flex;
  align-items: center;
}

/* 评论图标。 */
.action-icon {
  font-size: 28rpx;
}

/* 评论数量。 */
.action-text {
  font-size: 22rpx;
  color: #999999;
}

/* 发布时间。 */
.publish-time {
  font-size: 20rpx;
  color: #cccccc;
}
