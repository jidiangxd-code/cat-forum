/* miniprogram/pages/my-follows/my-follows.wxss - 关注关系页面样式 */
.page-container {
  min-height: 100vh;
  background-color: #FFF5EB;
  padding-bottom: 40rpx;
}
.page-container.dark {
  background-color: #1a1a2e;
}

/* 页面头部 */
.page-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 32rpx 24rpx;
  background: #fff;
  border-bottom: 1rpx solid #f0e8e0;
}
.page-container.dark .page-header {
  background: #252540;
  border-bottom-color: #333355;
}

/* 页面基础容器与整体背景样式。 */
.page-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #333;
}
.page-container.dark .page-title,
.page-container.dark .user-name {
  color: #f1f1ff;
}

.page-count {
  font-size: 26rpx;
  color: #999;
}
.page-container.dark .page-count,
.page-container.dark .user-id,
.page-container.dark .empty-text,
.page-container.dark .loading-text,
.page-container.dark .no-more-text {
  color: #9a9abc;
}

/* 用户列表 */
.user-list {
  background: #fff;
  margin: 24rpx;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.05);
}
.page-container.dark .user-list {
  background: #252540;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.25);
}

/* 用户头像、昵称和描述样式。 */
.user-item {
  display: flex;
  align-items: center;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid #f5f0eb;
}
.page-container.dark .user-item {
  border-bottom-color: #333355;
}

.user-item:last-child {
  border-bottom: none;
}

.user-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  margin-right: 24rpx;
  border: 3rpx solid #FFE4C4;
  flex-shrink: 0;
}
.page-container.dark .user-avatar {
  border-color: #3a3a5c;
}

.user-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  overflow: hidden;
}

.user-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.user-id {
  font-size: 22rpx;
  color: #bbb;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 关注按钮 */
.follow-btn {
  padding: 10rpx 32rpx;
  border-radius: 40rpx;
  font-size: 26rpx;
  font-weight: 600;
  background: #FF7043;
  color: #fff;
  flex-shrink: 0;
  border: none;
}

.follow-btn.following {
  background: #f5f5f5;
  color: #999;
}
.page-container.dark .follow-btn.following {
  background: #303052;
  color: #9a9abc;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

/* 空状态提示与占位样式。 */
.empty-icon {
  font-size: 96rpx;
  margin-bottom: 32rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

/* 加载状态 */
.loading-state {
  display: flex;
  justify-content: center;
  padding: 40rpx 0;
}

/* 加载提示与状态反馈样式。 */
.loading-text {
  font-size: 26rpx;
  color: #999;
}

/* 没有更多 */
.no-more {
  display: flex;
  justify-content: center;
  padding: 32rpx 0;
}

/* 结束态和无更多数据提示样式。 */
.no-more-text {
  font-size: 24rpx;
  color: #ccc;
}
