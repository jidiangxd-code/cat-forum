<!--pages/edit-profile/edit-profile.wxml - 漂亮完善的资料编辑界面-->
<view class="{{pageClass}}">

  <!-- 顶部头像区域 -->
  <view class="header-section">
    <view class="avatar-area" bind:tap="onChooseAvatar">
      <image
        class="avatar-img"
        src="{{avatarUrl || '/assets/images/default-avatar.png'}}"
        mode="aspectFill"
        binderror="onAvatarError"
      />
      <view class="avatar-badge">
        <text class="badge-icon">📷</text>
      </view>
    </view>
    <text class="avatar-hint">点击更换头像</text>
  </view>

  <!-- 表单卡片 -->
  <view class="form-card">

    <!-- 昵称 -->
    <view class="form-item">
      <view class="form-label-row">
        <text class="form-label">昵称</text>
        <text class="form-counter">{{nickName.length}}/20</text>
      </view>
      <view class="form-input-wrap">
        <input
          class="form-input"
          placeholder="请输入昵称（2-20字）"
          value="{{nickName}}"
          bindinput="onNickNameInput"
          maxlength="20"
        />
      </view>
    </view>

    <!-- 性别 -->
    <view class="form-item">
      <text class="form-label">性别</text>
      <view class="gender-row">
        <view
          wx:for="{{genderOptions}}"
          wx:key="value"
          class="gender-chip {{gender === item.value ? 'active' : ''}}"
          bindtap="onGenderTap"
          data-val="{{item.value}}"
        >
          {{item.label}}
        </view>
      </view>
    </view>

    <!-- 校区 -->
    <view class="form-item">
      <view class="form-label-row">
        <text class="form-label">校区</text>
      </view>
      <view class="form-input-wrap">
        <input
          class="form-input"
          placeholder="请输入你的校区"
          value="{{campus}}"
          bindinput="onCampusInput"
          maxlength="20"
        />
      </view>
    </view>

    <!-- 个性签名 -->
    <view class="form-item">
      <view class="form-label-row">
        <text class="form-label">个性签名</text>
        <text class="form-counter">{{bio.length}}/100</text>
      </view>
      <view class="bio-wrap">
        <textarea
          class="bio-input"
          placeholder="介绍一下自己吧～"
          value="{{bio}}"
          bindinput="onBioInput"
          maxlength="100"
          auto-height
        />
      </view>
    </view>

  </view>

  <!-- 保存按钮 -->
  <view class="btn-section">
    <button
      class="save-btn"
      bindtap="submitEdit"
      loading="{{saving}}"
      disabled="{{saving}}"
    >
      {{saving ? '保存中...' : '保存修改'}}
    </button>
  </view>

  <!-- 底部提示 -->
  <view class="footer-hint">
    <text class="hint-icon">🐱</text>
    <text class="hint-text">完善资料，让更多小伙伴认识你</text>
  </view>

</view>
