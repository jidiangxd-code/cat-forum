.page-container {
  min-height: 100vh;
  background: #FFF5EB;
  padding: 40rpx 30rpx;
}

/* 头像编辑区域 */
.avatar-section {
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.section-label {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 24rpx;
  font-weight: 500;
}

.avatar-editor {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-direction: column;
  padding: 40rpx 0;
}

.avatar-preview {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  margin-bottom: 20rpx;
  border: 4rpx solid #FFE0CC;
}

.avatar-tip {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.tip-icon {
  font-size: 40rpx;
  margin-bottom: 8rpx;
}

.tip-text {
  font-size: 26rpx;
  color: #999;
}

/* 表单区域 */
.form-section {
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.input-field {
  width: 100%;
  height: 88rpx;
  background: #F8F9FA;
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
  color: #333;
}

.char-count {
  text-align: right;
  font-size: 24rpx;
  color: #999;
  margin-top: 12rpx;
}

/* 保存按钮 */
.save-section {
  margin: 40rpx 0;
}

.save-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #FF9500, #FFB74D);
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(255, 149, 0, 0.3);
}

.save-btn[disabled] {
  background: #ccc;
  box-shadow: none;
}

/* 提示说明 */
.tips-section {
  padding: 20rpx;
}

.tip-item {
  display: flex;
  align-items: flex-start;
  margin-bottom: 16rpx;
}

.tip-item:last-child {
  margin-bottom: 0;
}

.tip-item .tip-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.tip-item .tip-text {
  font-size: 24rpx;
  color: #999;
  line-height: 1.6;
}
