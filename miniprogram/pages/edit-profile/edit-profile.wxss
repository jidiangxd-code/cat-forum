/* pages/edit-profile/edit-profile.wxss - 漂亮完善的资料编辑样式 */

.page-container {
  min-height: 100vh;
  background: var(--color-bg);
  padding: 0 0 120rpx 0;
}

/* ===== 顶部头像区域 ===== */
.header-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0 48rpx 0;
  background: var(--btn-primary-gradient);
  border-radius: 0 0 60rpx 60rpx;
  box-shadow: var(--color-shadow-card);
  margin-bottom: 40rpx;
}

.avatar-area {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 20rpx;
}

.avatar-img {
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  border: 6rpx solid #fff;
  box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.18);
  background: var(--color-bg-disabled);
}

.avatar-badge {
  position: absolute;
  right: 8rpx;
  bottom: 8rpx;
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: var(--btn-primary-gradient);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.15);
}

.badge-icon {
  font-size: 28rpx;
  color: #fff;
}

.avatar-hint {
  font-size: 24rpx;
  color: rgba(255,255,255,0.85);
  margin-top: 8rpx;
}

/* ===== 表单卡片 ===== */
.form-card {
  margin: 0 30rpx;
  background: var(--color-bg-card);
  border-radius: 28rpx;
  padding: 36rpx 32rpx;
  box-shadow: var(--color-shadow-card);
}

.form-item {
  margin-bottom: 40rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-label-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.form-label {
  font-size: 30rpx;
  color: var(--color-text-primary);
  font-weight: 600;
}

.form-counter {
  font-size: 22rpx;
  color: var(--color-text-muted);
}

/* ===== 输入框 ===== */
.form-input-wrap {
  position: relative;
}

.form-input {
  width: 100%;
  height: 88rpx;
  background: var(--color-bg-disabled);
  border-radius: 18rpx;
  padding: 0 28rpx;
  font-size: 30rpx;
  color: var(--color-text-primary);
  box-sizing: border-box;
  border: 2rpx solid transparent;
  transition: border-color 0.2s;
}

.form-input:focus {
  border-color: var(--color-primary);
  background: var(--color-bg-card);
}

.placeholder {
  color: var(--color-text-muted);
}

/* ===== 性别选择 ===== */
.gender-row {
  display: flex;
  gap: 20rpx;
}

.gender-chip {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  background: var(--color-bg-disabled);
  border-radius: 18rpx;
  font-size: 28rpx;
  color: var(--color-text-secondary);
  transition: all 0.2s;
  border: 2rpx solid transparent;
}

.gender-chip.active {
  background: var(--btn-primary-gradient);
  color: #fff;
  font-weight: 600;
  border-color: var(--color-primary);
  box-shadow: var(--color-shadow-btn);
}

/* ===== 校区 Picker ===== */
.picker-wrap {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 88rpx;
  background: var(--color-bg-disabled);
  border-radius: 18rpx;
  padding: 0 28rpx;
  font-size: 30rpx;
  color: var(--color-text-primary);
  border: 2rpx solid transparent;
  transition: border-color 0.2s;
}

.picker-wrap:active {
  border-color: var(--color-primary);
}

.picker-arrow {
  font-size: 28rpx;
  color: var(--color-text-muted);
}

.custom-campus {
  margin-top: 20rpx;
}

/* ===== 个性签名 ===== */
.bio-wrap {
  background: var(--color-bg-disabled);
  border-radius: 18rpx;
  padding: 20rpx 24rpx;
  border: 2rpx solid transparent;
  transition: border-color 0.2s;
}

.bio-wrap:focus-within {
  border-color: var(--color-primary);
  background: var(--color-bg-card);
}

.bio-input {
  width: 100%;
  min-height: 120rpx;
  font-size: 30rpx;
  color: var(--color-text-primary);
  line-height: 1.6;
  box-sizing: border-box;
}

/* ===== 保存按钮 ===== */
.btn-section {
  margin: 48rpx 30rpx 0 30rpx;
}

.save-btn {
  width: 100%;
  height: 104rpx;
  background: var(--btn-primary-gradient);
  color: #fff;
  font-size: 36rpx;
  font-weight: bold;
  border-radius: 52rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: var(--color-shadow-btn);
  letter-spacing: 4rpx;
  border: none;
}

.save-btn[disabled] {
  background: var(--color-bg-disabled);
  color: var(--color-text-muted);
  box-shadow: none;
}

/* ===== 底部提示 ===== */
.footer-hint {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  margin-top: 48rpx;
  padding: 0 30rpx;
}

.hint-icon {
  font-size: 28rpx;
}

.hint-text {
  font-size: 24rpx;
  color: var(--color-text-muted);
}
