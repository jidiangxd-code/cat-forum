.page-container {
  min-height: 100vh;
  background: #FFF5EB;
  padding: 30rpx;
  padding-bottom: 60rpx;
}

/* 通用卡片 */
.card {
  background: #fff;
  border-radius: 24rpx;
  padding: 36rpx 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.section-label {
  font-size: 28rpx;
  color: #333;
  font-weight: 600;
  margin-bottom: 28rpx;
}

/* ===== 头像 ===== */
.avatar-section {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.avatar-editor {
  position: relative;
  width: 180rpx;
  height: 180rpx;
}

.avatar-preview {
  width: 180rpx;
  height: 180rpx;
  border-radius: 50%;
  border: 4rpx solid #FFE0CC;
}

.avatar-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 56rpx;
  background: rgba(0, 0, 0, 0.45);
  border-radius: 0 0 50% 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
}

.overlay-icon {
  font-size: 24rpx;
}

.overlay-text {
  font-size: 22rpx;
  color: #fff;
}

/* ===== 表单行 ===== */
.form-row {
  display: flex;
  align-items: center;
  margin-bottom: 28rpx;
}

.form-row:last-child {
  margin-bottom: 0;
}

.form-label {
  width: 100rpx;
  font-size: 28rpx;
  color: #666;
  flex-shrink: 0;
}

.form-input-wrap {
  flex: 1;
  position: relative;
}

.input-field {
  width: 100%;
  height: 80rpx;
  background: #F8F9FA;
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #333;
}

.char-count {
  position: absolute;
  right: 20rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 22rpx;
  color: #bbb;
}

/* ===== 性别选择 ===== */
.gender-group {
  display: flex;
  gap: 16rpx;
  flex: 1;
}

.gender-item {
  flex: 1;
  height: 72rpx;
  line-height: 72rpx;
  text-align: center;
  background: #F8F9FA;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #666;
  transition: all 0.2s;
}

.gender-item.active {
  background: linear-gradient(135deg, #FF9500, #FFB74D);
  color: #fff;
  font-weight: 600;
  box-shadow: 0 4rpx 12rpx rgba(255, 149, 0, 0.3);
}

/* ===== 个性签名 ===== */
.bio-wrap {
  position: relative;
}

.bio-textarea {
  width: 100%;
  min-height: 120rpx;
  background: #F8F9FA;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
  line-height: 1.6;
}

.bio-count {
  position: static;
  transform: none;
  display: block;
  text-align: right;
  margin-top: 8rpx;
}

/* ===== 保存按钮 ===== */
.save-section {
  margin-top: 20rpx;
}

.save-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #FF9500, #FFB74D);
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(255, 149, 0, 0.3);
}

.save-btn[disabled] {
  background: #ccc;
  box-shadow: none;
}
