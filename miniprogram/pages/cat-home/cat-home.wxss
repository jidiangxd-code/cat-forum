/* pages/cat-home/cat-home.wxss */
.page { background: #FFF5EB; min-height: 100vh; padding-bottom: 60rpx; }
.page-loading {
  display: flex; align-items: center; justify-content: center;
  height: 100vh; font-size: 28rpx; color: #999;
}

/* 封面英雄区 */
.hero { position: relative; }
.cover-img { width: 100%; height: 480rpx; display: block; }
.cover-placeholder {
  width: 100%; height: 480rpx; background: linear-gradient(135deg, #FFE0C0, #FFBF9A);
  display: flex; align-items: center; justify-content: center; font-size: 120rpx;
}
.hero-info {
  padding: 24rpx 28rpx 20rpx;
  background: #fff;
}
.type-badge {
  display: inline-block; padding: 6rpx 20rpx; border-radius: 20rpx;
  font-size: 22rpx; font-weight: bold; margin-bottom: 12rpx;
}
.type-badge.formal { background: #FF9A6A; color: #fff; }
.type-badge.unknown { background: #88BBFF; color: #fff; }
.name-area { margin-bottom: 12rpx; }
.cat-name { font-size: 48rpx; font-weight: bold; color: #222; }
.code-name { font-size: 24rpx; color: #999; margin-left: 8rpx; }
.meta-row { display: flex; align-items: center; flex-wrap: wrap; gap: 8rpx; margin-bottom: 10rpx; }
.meta-item { font-size: 26rpx; color: #666; }
.meta-sep { color: #ccc; }
.status-row { display: flex; align-items: center; }
.status-dot { font-size: 20rpx; margin-right: 6rpx; }
.status-text { font-size: 24rpx; color: #555; }
.personality { font-size: 24rpx; color: #999; }

/* 健康标签 */
.health-tags-row { display: flex; flex-wrap: wrap; gap: 10rpx; margin-top: 12rpx; }
.health-tag {
  display: inline-block; padding: 4rpx 16rpx; border-radius: 20rpx;
  font-size: 22rpx; font-weight: 500;
}
.health-tag.normal { background: #E8F5E9; color: #2E7D32; }
.health-tag.warning { background: #FFF3E0; color: #E65100; }
.health-tag.warn { background: #FFFDE7; color: #F57F17; }

/* 票数区 */
.vote-section {
  display: flex; align-items: center; justify-content: space-between;
  background: #fff; margin: 16rpx 0; padding: 28rpx 32rpx;
}
.vote-count-area { display: flex; align-items: baseline; gap: 8rpx; }
.vote-big { font-size: 56rpx; font-weight: bold; color: #FF7043; }
.vote-unit { font-size: 24rpx; color: #999; }
.vote-btn {
  background: linear-gradient(135deg, #FF9A6A, #FF7043);
  color: #fff; padding: 20rpx 48rpx; border-radius: 44rpx;
  font-size: 28rpx; font-weight: bold;
}
.vote-btn.voted {
  background: #f0f0f0; color: #aaa;
}
.vote-btn.loading { opacity: 0.7; }

/* 功能按钮 */
.action-bar {
  display: flex; background: #fff;
  margin-bottom: 16rpx; border-top: 1rpx solid #f5f5f5;
}
.action-btn {
  flex: 1; display: flex; flex-direction: column; align-items: center;
  padding: 24rpx 0; font-size: 32rpx;
}
.action-btn + .action-btn { border-left: 1rpx solid #f5f5f5; }
.action-label { font-size: 22rpx; color: #555; margin-top: 8rpx; }
.promote-btn .action-label { color: #FF9A6A; font-weight: bold; }

/* ===== 猫咪动态时间线 ===== */
.timeline-section {
  background: #fff;
  margin: 16rpx 0;
  padding: 0 0 30rpx;
}
.timeline-header {
  display: flex;
  align-items: center;
  padding: 24rpx 28rpx 20rpx;
  border-bottom: 1rpx solid #f5f5f5;
}
.timeline-line {
  width: 6rpx;
  height: 32rpx;
  background: #FF9A6A;
  border-radius: 3rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
}
.timeline-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  flex: 1;
}
.timeline-count {
  font-size: 22rpx;
  color: #FF9A6A;
  background: #FFF5EB;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}

.timeline-list {
  padding: 0 28rpx;
}
.timeline-item {
  display: flex;
  align-items: flex-start;
  padding: 24rpx 0 0;
}
.timeline-dot {
  width: 16rpx;
  height: 16rpx;
  background: #FF9A6A;
  border-radius: 50%;
  margin-top: 10rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
  position: relative;
}
.timeline-item:not(:last-child) .timeline-dot::after {
  content: '';
  position: absolute;
  top: 20rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 2rpx;
  height: calc(100% + 14rpx);
  background: #FFD4BE;
}
.timeline-card {
  flex: 1;
  background: #FAFAFA;
  border-radius: 16rpx;
  padding: 20rpx;
  border: 1rpx solid #F5F0EE;
}
.timeline-card .post-imgs { margin-bottom: 12rpx; }
.timeline-card .post-content { margin-bottom: 12rpx; }
.timeline-card .post-text {
  -webkit-line-clamp: 4;
}
.timeline-card .post-footer {
  margin-top: 0;
}
.post-stats {
  font-size: 22rpx;
  color: #FF9A6A;
}


