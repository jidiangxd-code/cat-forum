/* pages/cat-home/cat-home.wxss - 猫咪主页样式（已迁移到 CSS 变量）*/
.page { background: var(--color-bg); min-height: 100vh; padding-bottom: 60rpx; }
.page-loading {
  display: flex; align-items: center; justify-content: center;
  height: 100vh; font-size: 28rpx; color: var(--color-text-secondary);
}

/* 封面英雄区 */
.hero { position: relative; }
.cover-img { width: 100%; height: 480rpx; display: block; }
.cover-placeholder {
  width: 100%; height: 480rpx; background: var(--banner-gradient);
  display: flex; align-items: center; justify-content: center; font-size: 120rpx;
}
.hero-info {
  padding: 24rpx 28rpx 20rpx;
  background: var(--color-bg-card);
}
.type-badge {
  display: inline-block; padding: 6rpx 20rpx; border-radius: 20rpx;
  font-size: 22rpx; font-weight: bold; margin-bottom: 12rpx;
}
.type-badge.formal { background: var(--color-bg-badge); color: var(--color-text-white); }
.type-badge.unknown { background: var(--color-text-blue); color: var(--color-text-white); }
.name-area { margin-bottom: 12rpx; }
.cat-name { font-size: 48rpx; font-weight: bold; color: var(--color-text-primary); }
.code-name { font-size: 24rpx; color: var(--color-text-secondary); margin-left: 8rpx; }
.meta-row { display: flex; align-items: center; flex-wrap: wrap; gap: 8rpx; margin-bottom: 10rpx; }
.meta-item { font-size: 26rpx; color: var(--color-text-secondary); }
.meta-sep { color: var(--color-text-muted); }
.status-row { display: flex; align-items: center; }
.status-dot { font-size: 20rpx; margin-right: 6rpx; }
.status-text { font-size: 24rpx; color: var(--color-text-secondary); }
.personality { font-size: 24rpx; color: var(--color-text-desc); }

/* 健康标签 */
.health-tags-row { display: flex; flex-wrap: wrap; gap: 10rpx; margin-top: 12rpx; }
.health-tag {
  display: inline-block; padding: 4rpx 16rpx; border-radius: 20rpx;
  font-size: 22rpx; font-weight: 500;
}
.health-tag.normal { background: var(--color-bg-tag-health); color: var(--color-text-tag-health); }
.health-tag.warning { background: var(--color-bg-tag); color: var(--color-text-accent); }
.health-tag.warn { background: var(--color-bg-tag); color: var(--color-text-accent); }

/* 票数区 */
.vote-section {
  display: flex; align-items: center; justify-content: space-between;
  background: var(--color-bg-card); margin: 16rpx 0; padding: 28rpx 32rpx;
}
.vote-count-area { display: flex; align-items: baseline; gap: 8rpx; }
.vote-big { font-size: 56rpx; font-weight: bold; color: var(--color-text-accent); }
.vote-unit { font-size: 24rpx; color: var(--color-text-secondary); }
.vote-btn {
  background: var(--btn-primary-gradient);
  color: var(--color-text-white); padding: 20rpx 48rpx; border-radius: 44rpx;
  font-size: 28rpx; font-weight: bold;
}
.vote-btn.voted {
  background: var(--color-bg-disabled); color: var(--color-text-muted);
}
.vote-btn.loading { opacity: 0.7; }

/* 功能按钮 */
.action-bar {
  display: flex; background: var(--color-bg-card);
  margin-bottom: 16rpx; border-top: 1rpx solid var(--color-border);
}
.action-btn {
  flex: 1; display: flex; flex-direction: column; align-items: center;
  padding: 24rpx 0; font-size: 32rpx;
}
.action-btn + .action-btn { border-left: 1rpx solid var(--color-border); }
.action-label { font-size: 22rpx; color: var(--color-text-secondary); margin-top: 8rpx; }
.promote-btn .action-label { color: var(--color-text-accent); font-weight: bold; }

/* ===== 猫咪动态时间线 ===== */
.timeline-section {
  background: var(--color-bg-card);
  margin: 16rpx 0;
  padding: 0 0 30rpx;
}
.timeline-header {
  display: flex;
  align-items: center;
  padding: 24rpx 28rpx 20rpx;
  border-bottom: 1rpx solid var(--color-border);
}
.timeline-line {
  width: 6rpx;
  height: 32rpx;
  background: var(--color-text-accent);
  border-radius: 3rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
}
.timeline-title {
  font-size: 28rpx;
  font-weight: bold;
  color: var(--color-text-primary);
  flex: 1;
}
.timeline-count {
  font-size: 22rpx;
  color: var(--color-text-accent);
  background: var(--color-bg);
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}

.timeline-list {
  padding: 0 28rpx;
}
.timeline-item {
  display: flex;
  align-items: flex-start;
  padding: 24rpx 0 0;
}
.timeline-dot {
  width: 16rpx;
  height: 16rpx;
  background: var(--color-text-accent);
  border-radius: 50%;
  margin-top: 10rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
  position: relative;
}
.timeline-item:not(:last-child) .timeline-dot::after {
  content: '';
  position: absolute;
  top: 20rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 2rpx;
  height: calc(100% + 14rpx);
  background: var(--color-border);
}
.timeline-card {
  flex: 1;
  background: var(--color-bg-disabled);
  border-radius: 16rpx;
  padding: 20rpx;
  border: 1rpx solid var(--color-border);
}
.timeline-card .post-imgs { margin-bottom: 12rpx; }
.timeline-card .post-content { margin-bottom: 12rpx; }
.timeline-card .post-text {
  -webkit-line-clamp: 4;
}
.timeline-card .post-footer {
  margin-top: 0;
}
.post-stats {
  font-size: 22rpx;
  color: var(--color-text-accent);
}
