<!--详情页 - 帖子详情 + 评论（含子评论/回复）-->
<view class="page-container" wx:if="{{post}}">
  <!-- 发布者信息（独立区块） -->
  <view class="author-card" wx:if="{{post.authorId && post.authorId !== 'guest'}}">
    <view class="author-left" bindtap="onAuthorTap">
      <image
        class="author-avatar"
        src="{{authorAvatarError ? '/assets/images/default-avatar.png' : (post.authorAvatar || '/assets/images/default-avatar.png')}}"
        mode="aspectFill"
        binderror="onAuthorAvatarError"
      />
      <view class="author-info">
        <text class="author-name">{{post.authorName || '爱猫同学'}}</text>
        <text class="author-meta">{{post.createTimeStr || ''}}{{post.location ? ' · ' + post.location : ''}}</text>
      </view>
    </view>
    <view
      class="follow-btn {{isFollowing ? 'following' : ''}}"
      bindtap="toggleFollow"
      wx:if="{{post.authorId && post.authorId !== currentUserId}}"
    >
      <text>{{isFollowing ? '已关注' : '+ 关注'}}</text>
    </view>
  </view>

  <!-- 图片轮播 -->
  <swiper class="image-swiper" indicator-dots circular autoplay wx:if="{{post.images && post.images.length > 0}}">
    <swiper-item wx:for="{{post.images}}" wx:key="*this">
      <image
        src="{{item}}"
        mode="aspectFill"
        class="swiper-image"
        bindtap="previewImage"
        data-images="{{post.images}}"
        data-index="{{index}}"
      />
    </swiper-item>
  </swiper>

  <!-- 猫咪信息卡片 -->
  <view class="info-card">
    <!-- 猫咪头部（可点击跳转猫咪主页） -->
    <view class="cat-header" bindtap="onCatTap" wx:if="{{cat}}">
      <image
        class="cat-avatar"
        src="{{cat.coverImage || '/assets/images/default-cat.png'}}"
        mode="aspectFill"
        binderror="onAvatarError"
      />
      <view class="cat-header-info">
        <text class="cat-header-name">{{cat.fullName || cat.codeName}}</text>
        <text class="cat-header-meta">{{cat.appearance}} · {{cat.gender === 'male' ? '♂公' : cat.gender === 'female' ? '♀母' : ''}} · {{cat.location || '地点未知'}}</text>
      </view>
      <view class="cat-type-badge {{cat.catType}}">
        {{cat.catType === 'formal' ? '正式' : '未知'}}
      </view>
      <text class="cat-arrow">›</text>
    </view>

    <view class="divider" wx:if="{{cat}}"></view>

    <!-- 帖子内容 -->
    <view class="post-content-section">
      <text class="post-text">{{post.content}}</text>
    </view>

    <!-- 发布时间 -->
    <view class="post-meta">
      <text class="post-time">{{post.createTimeStr || ''}}</text>
      <view class="location-tag" wx:if="{{post.location}}">
        <text>📍 {{post.location}}</text>
      </view>
    </view>
  </view>

  <!-- 互动区域 -->
  <view class="action-bar">
    <view class="action-item" bindtap="toggleLike">
      <text class="action-icon {{liked ? 'liked' : ''}}">{{liked ? '❤️' : '🤍'}}</text>
      <text class="action-text">{{liked ? '已喜欢' : '喜欢'}}</text>
      <text class="action-count">{{post.likeCount || 0}}</text>
    </view>
    <view class="action-item" bindtap="toggleFavorite">
      <text class="action-icon">{{favorited ? '⭐' : '☆'}}</text>
      <text class="action-text">{{favorited ? '已收藏' : '收藏'}}</text>
    </view>
    <view class="action-item">
      <text class="action-icon">💬</text>
      <text class="action-text">评论</text>
      <text class="action-count">{{post.commentCount || comments.length}}</text>
    </view>
    <button class="action-item share-btn" open-type="share">
      <text class="action-icon">📤</text>
      <text class="action-text">分享</text>
    </button>
    <view class="action-item" bindtap="showMoreMenu">
        <text class="action-icon">⋯</text>
        <text class="action-text">更多</text>
    </view>
  </view>

  <!-- 举报弹窗 -->
  <view class="report-overlay" wx:if="{{showReport}}" bindtap="hideReport">
    <view class="report-modal" catchtap="">
      <text class="report-title">举报内容</text>
      <text class="report-subtitle">请选择举报原因</text>
      <view class="report-reasons">
        <view class="report-reason-item {{selectedReason === item.value ? 'selected' : ''}}" wx:for="{{reportReasons}}" wx:key="value" bindtap="selectReason" data-value="{{item.value}}">
          <text class="reason-icon">{{item.icon}}</text>
          <text class="reason-text">{{item.label}}</text>
          <text class="reason-check" wx:if="{{selectedReason === item.value}}">✓</text>
        </view>
      </view>
      <textarea class="report-desc" placeholder="补充说明（选填）" maxlength="200" bindinput="onReportDescInput" value="{{reportDescription}}" />
      <view class="report-actions">
        <view class="report-btn report-cancel-btn" bindtap="hideReport">取消</view>
        <view class="report-btn report-submit-btn {{selectedReason ? '' : 'disabled'}}" bindtap="submitReport">提交举报</view>
      </view>
    </view>
  </view>

  <!-- 举报成功提示 -->
  <view class="report-success-toast" wx:if="{{reportSuccess}}">
    <text class="toast-icon">✅</text>
    <text class="toast-text">举报已提交，我们会尽快处理</text>
  </view>

  <!-- 评论区 -->
  <view class="comment-section">
    <view class="section-title">
      <text>💬 评论 ({{post.commentCount || comments.length}})</text>
    </view>

    <!-- 评论列表：主评论 + 子评论嵌套 -->
    <view class="comment-list" wx:if="{{comments.length > 0}}">
      <!-- 主评论 -->
      <view class="comment-item {{!item.read ? 'comment-unread' : ''}}" wx:for="{{comments}}" wx:key="_id" wx:if="{{!item.parentId}}">
        <image
          class="comment-avatar"
          src="{{item.avatarError ? '/assets/images/default-avatar.png' : (item.authorAvatar || '/assets/images/default-avatar.png')}}"
          mode="aspectFill"
          binderror="onCommentAvatarError"
          data-index="{{index}}"
        />
        <view class="comment-body">
          <view class="comment-top">
            <text class="comment-author">{{item.authorName}}</text>
            <text class="comment-time">{{item.timeStr || item.createTime}}</text>
          </view>
          <text class="comment-text">{{item.content}}</text>
          <!-- 回复按钮 -->
          <view class="comment-actions">
            <text class="reply-btn" bindtap="onReplyComment" data-comment="{{item}}">回复</text>
          </view>

          <!-- 子评论列表 -->
          <view class="reply-list" wx:if="{{item.replies && item.replies.length > 0}}">
            <view class="reply-item" wx:for="{{item.replies}}" wx:key="_id" wx:for-item="reply">
              <view class="reply-header">
                <image
                  class="reply-avatar"
                  src="{{reply.avatarError ? '/assets/images/default-avatar.png' : (reply.authorAvatar || '/assets/images/default-avatar.png')}}"
                  mode="aspectFill"
                  binderror="onReplyAvatarError"
                  data-index="{{index}}"
                  data-parent="{{index}}"
                />
                <text class="reply-author">{{reply.authorName}}</text>
                <text class="reply-connector" wx:if="{{reply.replyToUserName}}">回复</text>
                <text class="reply-to" wx:if="{{reply.replyToUserName}}">@{{reply.replyToUserName}}</text>
                <text class="comment-time">{{reply.timeStr || reply.createTime}}</text>
              </view>
              <text class="reply-text">{{reply.content}}</text>
            </view>
          </view>
        </view>
      </view>
    </view>

    <view class="empty-comment" wx:else>
      <text class="empty-icon">💭</text>
      <text class="empty-text">还没有评论，快来抢沙发！</text>
    </view>
  </view>

  <!-- 底部评论输入 -->
  <view class="comment-input-bar" style="padding-bottom: {{isReply ? '160rpx' : '16rpx'}}">
    <!-- 回复提示条 -->
    <view class="reply-hint-bar" wx:if="{{isReply}}">
      <text class="reply-hint-text">回复 @{{replyToUserName}}</text>
      <text class="reply-cancel" bindtap="onCancelReply">取消</text>
    </view>
    <view class="input-row">
      <input
        class="comment-input"
        placeholder="{{replyPlaceholder}}"
        value="{{inputContent}}"
        bindinput="onInputComment"
        bindconfirm="submitComment"
        focus="{{isReply}}"
      />
      <view class="send-btn" bindtap="submitComment">
        <text>发送</text>
      </view>
    </view>
  </view>
</view>

<!-- 加载中 -->
<view class="loading-page" wx:if="{{loading}}">
  <text class="loading-icon">🐾</text>
  <text class="loading-text">加载中...</text>
</view>