<!--详情页 - 帖子详情 + 评论-->
<view class="page-container" wx:if="{{post}}">
  <!-- 图片轮播 -->
  <swiper class="image-swiper" indicator-dots circular autoplay wx:if="{{post.images && post.images.length > 0}}">
    <swiper-item wx:for="{{post.images}}" wx:key="*this">
      <image
        src="{{item}}"
        mode="aspectFill"
        class="swiper-image"
        bindtap="previewImage"
        data-images="{{post.images}}"
        data-index="{{index}}"
      />
    </swiper-item>
  </swiper>

  <!-- 发布者信息 -->
  <view class="author-section">
    <view class="author-info-row">
      <image
        class="author-avatar"
        src="{{post.authorAvatar || '/assets/images/default-avatar.png'}}"
        mode="aspectFill"
        binderror="onAvatarError"
      />
      <view class="author-details">
        <text class="author-name">{{post.authorName || '匿名用户'}}</text>
        <text class="post-time">{{post.createTimeStr || ''}}</text>
      </view>
    </view>
    <view class="location-tag" wx:if="{{post.location}}">
      <text>📍 {{post.location}}</text>
    </view>
  </view>

  <!-- 分类标签 -->
  <view class="category-section" wx:if="{{post.category}}">
    <view class="category-tag">
      {{categoryMap[post.category] || post.category}}
    </view>
  </view>

  <!-- 关联猫咪信息卡片（可点击跳转） -->
  <view class="cat-card" wx:if="{{cat}}" bindtap="onCatTap">
    <image
      class="cat-cover"
      src="{{cat.coverImage || '/assets/images/default-cat.png'}}"
      mode="aspectFill"
    />
    <view class="cat-info">
      <view class="cat-name-row">
        <text class="cat-name">{{cat.fullName || cat.codeName}}</text>
        <view class="cat-type-badge {{cat.catType}}">
          {{cat.catType === 'formal' ? '正式猫' : '未知猫'}}
        </view>
      </view>
      <text class="cat-meta">{{cat.appearance}} · {{cat.gender === 'male' ? '♂公' : cat.gender === 'female' ? '♀母' : '性别未知'}} · {{cat.location || '地点未知'}}</text>
      <view class="cat-stats" wx:if="{{cat.totalVote}}">
        <text>🔥 {{cat.totalVote}} 人投票</text>
      </view>
    </view>
    <text class="cat-arrow">›</text>
  </view>

  <!-- 帖子内容 -->
  <view class="post-content-section">
    <text class="post-text">{{post.content}}</text>
  </view>

  <!-- 互动区域 -->
  <view class="action-bar">
    <view class="action-item" bindtap="toggleLike">
      <text class="action-icon {{liked ? 'liked' : ''}}">{{liked ? '❤️' : '🤍'}}</text>
      <text class="action-text">{{liked ? '已喜欢' : '喜欢'}}</text>
      <text class="action-count">{{post.likeCount || 0}}</text>
    </view>
    <view class="action-item" bindtap="toggleFavorite">
      <text class="action-icon">{{favorited ? '⭐' : '☆'}}</text>
      <text class="action-text">{{favorited ? '已收藏' : '收藏'}}</text>
    </view>
    <view class="action-item">
      <text class="action-icon">💬</text>
      <text class="action-text">评论</text>
      <text class="action-count">{{post.commentCount || comments.length}}</text>
    </view>
    <button class="action-item share-btn" open-type="share">
      <text class="action-icon">📤</text>
      <text class="action-text">分享</text>
    </button>
  </view>

  <!-- 评论区 -->
  <view class="comment-section">
    <view class="section-title">
      <text>💬 评论 ({{comments.length}})</text>
    </view>

    <view class="comment-list" wx:if="{{comments.length > 0}}">
      <view class="comment-item" wx:for="{{comments}}" wx:key="_id">
        <image class="comment-avatar" src="{{item.avatarError ? '/assets/images/default-avatar.png' : (item.authorAvatar || '/assets/images/default-avatar.png')}}" mode="aspectFill" binderror="onCommentAvatarError" data-index="{{index}}" />
        <view class="comment-content">
          <text class="comment-author">{{item.authorName}}</text>
          <text class="comment-text">{{item.content}}</text>
          <text class="comment-time">{{item.timeStr || item.createTime}}</text>
        </view>
      </view>
    </view>

    <view class="empty-comment" wx:else>
      <text class="empty-icon">💭</text>
      <text class="empty-text">还没有评论，快来抢沙发！</text>
    </view>
  </view>

  <!-- 底部评论输入 -->
  <view class="comment-input-bar">
    <input
      class="comment-input"
      placeholder="说点什么吧..."
      value="{{inputContent}}"
      bindinput="onInputComment"
      bindconfirm="submitComment"
    />
    <view class="send-btn" bindtap="submitComment">
      <text>发送</text>
    </view>
  </view>
</view>

<!-- 加载中 -->
<view class="loading-page" wx:if="{{loading}}">
  <text class="loading-icon">🐾</text>
  <text class="loading-text">加载中...</text>
</view>
