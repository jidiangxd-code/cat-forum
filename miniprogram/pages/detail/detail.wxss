/* miniprogram/pages/detail/detail.wxss - 帖子详情页面样式 */
.page-container {
  min-height: 100vh;
  padding-bottom: 120rpx;
  background-color: #fff5eb;
}

/* 发布者信息卡片 */
.author-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  background: #fff;
  border-bottom: 1rpx solid #f0e8e0;
}

.author-left {
  display: flex;
  align-items: center;
  flex: 1;
}

.author-avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  margin-right: 20rpx;
  border: 3rpx solid #FFE4C4;
}

.author-info {
  display: flex;
  flex-direction: column;
}

.author-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 6rpx;
}

.author-meta {
  font-size: 24rpx;
  color: #999;
}

.follow-btn {
  padding: 10rpx 28rpx;
  border-radius: 40rpx;
  font-size: 26rpx;
  font-weight: 600;
  background: #FF7043;
  color: #fff;
  border: none;
  white-space: nowrap;
}

.follow-btn.following {
  background: #f5f5f5;
  color: #999;
}

