/* pages/detail/detail.wxss - 详情页样式（已迁移到 CSS 变量）*/

/* 页面底部留白，防止评论被固定输入框遮挡 */
.page {
  padding-bottom: 220rpx;
}

.page-container {
  min-height: 100vh;
  padding-bottom: 120rpx;
  background-color: var(--color-bg);
}

/* 发布者信息卡片 */
.author-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  background: var(--color-bg-card);
  border-bottom: 1rpx solid var(--color-border);
}

.author-left {
  display: flex;
  align-items: center;
  flex: 1;
}

.author-avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  margin-right: 20rpx;
  border: 3rpx solid var(--color-border-accent);
}

.author-info {
  display: flex;
  flex-direction: column;
}

.author-name {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  margin-bottom: 6rpx;
}

.author-meta {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.follow-btn {
  padding: 10rpx 28rpx;
  border-radius: 40rpx;
  font-size: 26rpx;
  font-weight: 600;
  background: var(--color-bg-btn-primary);
  color: var(--color-text-white);
  border: none;
  white-space: nowrap;
}

.follow-btn.following {
  background: var(--color-bg-disabled);
  color: var(--color-text-secondary);
}

/* 图片轮播 */
.image-swiper {
  width: 100%;
  height: 600rpx;
}

.swiper-image {
  width: 100%;
  height: 600rpx;
}

/* 发布者信息 */
.author-section {
  margin: -40rpx 24rpx 20rpx;
  background: var(--color-bg-card);
  border-radius: 24rpx;
  padding: 24rpx;
  box-shadow: var(--color-shadow-card);
  position: relative;
  z-index: 10;
}
.author-info-row {
  display: flex;
  align-items: center;
}
.author-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  margin-right: 16rpx;
  border: 3rpx solid var(--color-border-accent);
  background: var(--color-bg-image);
}
.author-details {
  flex: 1;
}
.author-name {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  display: block;
}
.post-time {
  font-size: 22rpx;
  color: var(--color-text-desc);
  margin-top: 4rpx;
  display: block;
}
.location-tag {
  background-color: var(--color-bg-tag);
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  color: var(--color-text-accent);
  display: inline-block;
  margin-top: 12rpx;
}

/* 分类标签 */
.category-section {
  margin: 0 24rpx 20rpx;
}
.category-tag {
  display: inline-block;
  background: var(--color-bg-tag);
  color: var(--color-text-accent);
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: 500;
}

/* 关联猫咪卡片 */
.cat-card {
  margin: 0 24rpx 20rpx;
  background: var(--primary-gradient);
  border-radius: 24rpx;
  padding: 20rpx;
  display: flex;
  align-items: center;
  box-shadow: var(--color-shadow-card);
}
.cat-cover {
  width: 100rpx;
  height: 100rpx;
  border-radius: 16rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
  background: var(--color-bg-card);
}
.cat-info {
  flex: 1;
}
.cat-name-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 6rpx;
}
.cat-name {
  font-size: 30rpx;
  font-weight: bold;
  color: var(--color-text-accent);
}
.cat-type-badge {
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
  font-size: 20rpx;
  font-weight: bold;
}
.cat-type-badge.formal { background: var(--color-bg-badge); color: var(--color-text-white); }
.cat-type-badge.unknown { background: var(--color-text-blue); color: var(--color-text-white); }
.cat-meta {
  font-size: 22rpx;
  color: var(--color-text-secondary);
  display: block;
  margin-top: 4rpx;
}
.cat-stats {
  font-size: 22rpx;
  color: var(--color-text-accent);
  margin-top: 6rpx;
}
.cat-arrow {
  font-size: 40rpx;
  color: var(--color-text-accent);
  margin-left: 12rpx;
}

/* 帖子内容 */
.post-content-section {
  margin: 0 24rpx 20rpx;
  background: var(--color-bg-card);
  border-radius: 24rpx;
  padding: 24rpx;
  box-shadow: var(--color-shadow-card);
}
.post-text {
  font-size: 30rpx;
  color: var(--color-text-primary);
  line-height: 1.8;
  word-break: break-all;
}

/* 分享按钮重置 */
.share-btn {
  background: transparent !important;
  border: none !important;
  padding: 0 !important;
  margin: 0 !important;
  line-height: normal !important;
}
.share-btn::after { border: none; }

/* 互动区域 */
.action-bar {
  display: flex;
  margin: 20rpx 24rpx;
  background-color: var(--color-bg-card);
  border-radius: 20rpx;
  padding: 24rpx 0;
  box-shadow: var(--color-shadow-card);
}

.action-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
}

.action-icon {
  font-size: 40rpx;
  line-height: 1;
}

.action-icon.liked {
  animation: likeAnim 0.3s ease;
}

@keyframes likeAnim {
  0% { transform: scale(1); }
  50% { transform: scale(1.4); }
  100% { transform: scale(1); }
}

.action-text {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  line-height: 1;
}

.action-count {
  font-size: 22rpx;
  color: var(--color-text-desc);
  line-height: 1;
}

/* 评论区 */
.comment-section {
  margin: 20rpx 24rpx;
  background-color: var(--color-bg-card);
  border-radius: 20rpx;
  padding: 24rpx;
  box-shadow: var(--color-shadow-card);
}

.comment-list {
  margin-top: 20rpx;
  max-height: 600rpx;
  overflow-y: auto;
}

.comment-item {
  display: flex;
  padding: 20rpx 0;
  border-bottom: 1rpx solid var(--color-border);
}

.comment-item:last-child {
  border-bottom: none;
}

/* 未读评论左侧竖线 */
.comment-unread {
  border-left: 4rpx solid var(--color-text-accent);
  padding-left: 12rpx !important;
  margin-left: -12rpx;
}

/* 整体评论结构 */
.comment-body {
  flex: 1;
  min-width: 0;
}

.comment-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 4rpx;
}

.comment-avatar {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.comment-content {
  flex: 1;
}

.comment-author {
  font-size: 26rpx;
  font-weight: bold;
  color: var(--color-text-primary);
  display: block;
}

.comment-text {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  margin: 8rpx 0;
  display: block;
  line-height: 1.6;
}

.comment-time {
  font-size: 20rpx;
  color: var(--color-text-muted);
  display: block;
}

/* 评论头部：作者名 + 时间同行 */
.comment-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 6rpx;
}

.comment-header .comment-time {
  display: inline;
  margin-left: 12rpx;
}

/* 自己评论的删除按钮 */
.comment-delete-btn {
  flex-shrink: 0;
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: var(--color-text-muted);
  opacity: 0.6;
}

.comment-delete-btn:active {
  opacity: 1;
  color: #f44336;
}

/* 回复操作按钮 */
.comment-actions {
  display: flex;
  align-items: center;
  margin-top: 6rpx;
}

.reply-btn {
  font-size: 22rpx;
  color: var(--color-text-accent);
  padding: 4rpx 12rpx;
  background: var(--color-bg);
  border-radius: 12rpx;
}

/* 子评论列表 */
.reply-list {
  margin-top: 12rpx;
  background: var(--color-bg-disabled);
  border-radius: 12rpx;
  padding: 12rpx 16rpx;
  border-left: 3rpx solid var(--color-border-accent);
}

.reply-item {
  display: flex;
  flex-direction: column;
  padding: 8rpx 0;
}

.reply-item + .reply-item {
  border-top: 1rpx solid var(--color-border);
  padding-top: 12rpx;
  margin-top: 8rpx;
}

.reply-header {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 4rpx;
  flex-wrap: wrap;
}

.reply-avatar {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.reply-author {
  font-size: 24rpx;
  font-weight: bold;
  color: var(--color-text-primary);
}

.reply-connector {
  font-size: 22rpx;
  color: var(--color-text-secondary);
}

.reply-to {
  font-size: 24rpx;
  color: var(--color-text-accent);
  font-weight: bold;
}

.reply-text {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  line-height: 1.5;
  padding-left: 48rpx;
  word-break: break-all;
}

.empty-comment {
  text-align: center;
  padding: 40rpx;
}

.empty-icon {
  font-size: 60rpx;
  display: block;
  margin-bottom: 10rpx;
}

.empty-text {
  font-size: 24rpx;
  color: var(--color-text-muted);
}

/* 底部评论输入 */
.comment-input-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: var(--color-bg-card);
  padding: 16rpx 24rpx;
  display: flex;
  align-items: center;
  border-top: 1rpx solid var(--color-border);
  box-shadow: var(--color-shadow-modal);
  z-index: 100;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
}

.input-wrap {
  flex: 1;
  display: flex;
  align-items: center;
  background-color: var(--color-bg-disabled);
  border-radius: 40rpx;
  padding: 8rpx 8rpx 8rpx 20rpx;
  transition: all 0.2s;
}

.input-wrap:focus-within {
  background-color: var(--color-bg-card);
  box-shadow: 0 0 0 2rpx var(--color-text-accent);
}

.input-avatar {
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  margin-right: 14rpx;
  flex-shrink: 0;
  border: 2rpx solid var(--color-border);
}

.comment-input {
  flex: 1;
  font-size: 28rpx;
  color: var(--color-text-primary);
  min-height: 52rpx;
}

.comment-input::placeholder {
  color: var(--color-text-muted);
}

.char-count {
  font-size: 22rpx;
  color: var(--color-text-muted);
  margin-right: 8rpx;
  flex-shrink: 0;
}

.send-btn {
  background: var(--btn-primary-gradient);
  color: var(--color-text-white);
  border-radius: 36rpx;
  padding: 18rpx 32rpx;
  margin-left: 16rpx;
  font-size: 28rpx;
  font-weight: bold;
  white-space: nowrap;
  transition: all 0.2s;
  box-shadow: var(--color-shadow-btn);
}

.send-btn.disabled {
  background: var(--color-bg-disabled);
  color: var(--color-text-muted);
  box-shadow: none;
}

/* 加载状态 */
.loading-page {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100vh;
  background-color: var(--color-bg);
}

.loading-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.loading-text {
  font-size: 28rpx;
  color: var(--color-text-secondary);
}

/* ==================== 举报弹窗 ==================== */
.report-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  z-index: 999;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

.report-modal {
  background-color: var(--color-bg-card);
  border-radius: 32rpx 32rpx 0 0;
  padding: 40rpx 32rpx;
  width: 100%;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
  animation: slideUp 0.3s ease;
}

@keyframes slideUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}

.report-title {
  font-size: 36rpx;
  font-weight: bold;
  color: var(--color-text-primary);
  display: block;
  text-align: center;
  margin-bottom: 8rpx;
}

.report-subtitle {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  display: block;
  text-align: center;
  margin-bottom: 24rpx;
}

.report-reasons {
  margin-bottom: 24rpx;
}

.report-reason-item {
  display: flex;
  align-items: center;
  padding: 24rpx 20rpx;
  border-radius: 16rpx;
  margin-bottom: 12rpx;
  background-color: var(--color-bg-disabled);
  border: 2rpx solid transparent;
  transition: all 0.2s;
}

.report-reason-item.selected {
  background-color: var(--color-bg);
  border-color: var(--color-text-accent);
}

.reason-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
}

.reason-text {
  flex: 1;
  font-size: 30rpx;
  color: var(--color-text-primary);
}

.reason-check {
  font-size: 32rpx;
  color: var(--color-text-accent);
  font-weight: bold;
}

.report-desc {
  width: 100%;
  height: 120rpx;
  background-color: var(--color-bg-disabled);
  border-radius: 16rpx;
  padding: 16rpx 20rpx;
  font-size: 28rpx;
  color: var(--color-text-primary);
  margin-bottom: 24rpx;
  box-sizing: border-box;
}

.report-actions {
  display: flex;
  gap: 20rpx;
}

.report-btn {
  flex: 1;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: bold;
}

.report-cancel-btn {
  background-color: var(--color-bg-disabled);
  color: var(--color-text-secondary);
}

.report-submit-btn {
  background: var(--btn-primary-gradient);
  color: var(--color-text-white);
}

.report-submit-btn.disabled {
  opacity: 0.5;
}

.report-success-toast {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  background-color: rgba(0, 0, 0, 0.8);
  border-radius: 24rpx;
  padding: 32rpx 48rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  z-index: 1000;
}

.report-success-toast .toast-icon {
  font-size: 60rpx;
  margin-bottom: 12rpx;
}

.report-success-toast .toast-text {
  font-size: 28rpx;
  color: var(--color-text-white);
}

/* ==================== 纠错功能样式 ==================== */

/* 猫咪卡片外层容器 */
.cat-card-wrapper {
  margin: 20rpx 24rpx 0;
}

/* 纠错按钮（仅作者可见） */
.correct-cat-btn {
  display: flex;
  justify-content: flex-end;
  padding: 8rpx 16rpx 0;
}

.correct-cat-btn text {
  font-size: 24rpx;
  color: var(--color-text-accent);
  font-weight: 500;
}

/* 未归档状态提示 */
.cat-card-unbound {
  margin: 20rpx 24rpx 0;
  padding: 32rpx;
  background: var(--color-bg-card);
  border-radius: 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  border: 2rpx dashed var(--color-border);
}

.unbound-icon {
  font-size: 48rpx;
}

.unbound-text {
  font-size: 26rpx;
  color: var(--color-text-secondary);
}

.unbound-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 8rpx;
}

.unbound-action-btn {
  padding: 16rpx 32rpx;
  border-radius: 32rpx;
  font-size: 26rpx;
  background: var(--color-bg-disabled);
  color: var(--color-text-secondary);
}

.unbound-action-btn.primary {
  background: var(--color-bg-btn-primary);
  color: var(--color-text-white);
}
