.page-container {
  min-height: 100vh;
  padding-bottom: 120rpx;
  background-color: #FFF5EB;
}

/* 发布者信息卡片 */
.author-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  background: #fff;
  border-bottom: 1rpx solid #f0e8e0;
}

.author-left {
  display: flex;
  align-items: center;
  flex: 1;
}

.author-avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  margin-right: 20rpx;
  border: 3rpx solid #FFE4C4;
}

.author-info {
  display: flex;
  flex-direction: column;
}

.author-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 6rpx;
}

.author-meta {
  font-size: 24rpx;
  color: #999;
}

.follow-btn {
  padding: 10rpx 28rpx;
  border-radius: 40rpx;
  font-size: 26rpx;
  font-weight: 600;
  background: #FF7043;
  color: #fff;
  border: none;
  white-space: nowrap;
}

.follow-btn.following {
  background: #f5f5f5;
  color: #999;
}

/* 图片轮播 */
.image-swiper {
  width: 100%;
  height: 600rpx;
}

.swiper-image {
  width: 100%;
  height: 600rpx;
}

/* 信息卡片 */
.info-card {
  margin: -40rpx 24rpx 20rpx;
  background-color: #ffffff;
  border-radius: 24rpx;
  padding: 30rpx;
  box-shadow: 0 8rpx 24rpx rgba(255, 154, 106, 0.2);
  position: relative;
  z-index: 10;
}

.info-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.avatar-row {
  display: flex;
  align-items: center;
}

.avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  margin-right: 16rpx;
  border: 3rpx solid #FFE0CC;
}

.user-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #4A4A4A;
  display: block;
}

.publish-time {
  font-size: 22rpx;
  color: #999999;
  margin-top: 6rpx;
  display: block;
}

.location-tag {
  background-color: #FFF0E0;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  color: #E67E22;
}

/* 猫咪名字区域 */
.cat-name-section {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.cat-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #6B4226;
}

.category-tag {
  padding: 8rpx 24rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
}

.category-tag.stray {
  background-color: #E8F5E9;
  color: #4CAF50;
}

.category-tag.pet {
  background-color: #E3F2FD;
  color: #2196F3;
}

.category-tag.lost {
  background-color: #FFF3E0;
  color: #FF9800;
}

/* 描述 */
.description {
  font-size: 28rpx;
  color: #666666;
  line-height: 1.8;
  word-break: break-all;
}

/* 猫咪头部 */
.cat-header {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}
.cat-avatar {
  width: 72rpx; height: 72rpx; border-radius: 50%; margin-right: 16rpx;
  overflow: hidden; flex-shrink: 0; border: 3rpx solid #FFE0CC;
}
.cat-header-info { flex: 1; }
.cat-header-name { display: block; font-size: 28rpx; font-weight: bold; color: #333; }
.cat-header-meta { display: block; font-size: 22rpx; color: #999; margin-top: 4rpx; }
.cat-type-badge {
  padding: 4rpx 16rpx; border-radius: 12rpx; font-size: 20rpx; font-weight: bold; margin-right: 12rpx;
}
.cat-type-badge.formal { background: #FF9A6A; color: #fff; }
.cat-type-badge.unknown { background: #88BBFF; color: #fff; }
.cat-arrow { font-size: 32rpx; color: #ccc; }

/* 帖子内容 */
.post-content-section { margin: 16rpx 0; }
.post-text { font-size: 30rpx; color: #333; line-height: 1.8; word-break: break-all; }

/* 帖子元信息 */
.post-meta {
  display: flex; align-items: center; gap: 16rpx; margin-top: 16rpx;
}
.post-time { font-size: 22rpx; color: #bbb; }

/* 分享按钮重置 */
.share-btn {
  background: transparent !important;
  border: none !important;
  padding: 0 !important;
  margin: 0 !important;
  line-height: normal !important;
}
.share-btn::after { border: none; }

/* 互动区域 */
.action-bar {
  display: flex;
  margin: 20rpx 24rpx;
  background-color: #ffffff;
  border-radius: 20rpx;
  padding: 24rpx 0;
  box-shadow: 0 4rpx 12rpx rgba(255, 154, 106, 0.1);
}

.action-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
}

.action-icon {
  font-size: 40rpx;
  line-height: 1;
}

.action-icon.liked {
  animation: likeAnim 0.3s ease;
}

@keyframes likeAnim {
  0% { transform: scale(1); }
  50% { transform: scale(1.4); }
  100% { transform: scale(1); }
}

.action-text {
  font-size: 24rpx;
  color: #666666;
  line-height: 1;
}

.action-count {
  font-size: 22rpx;
  color: #999999;
  line-height: 1;
}

/* 评论区 */
.comment-section {
  margin: 20rpx 24rpx;
  background-color: #ffffff;
  border-radius: 20rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(255, 154, 106, 0.1);
}

.comment-list {
  margin-top: 20rpx;
  max-height: 600rpx;
  overflow-y: auto;
}

.comment-item {
  display: flex;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #F5F5F5;
}

.comment-item:last-child {
  border-bottom: none;
}

/* 未读评论左侧竖线 */
.comment-unread {
  border-left: 4rpx solid #FF9A6A;
  padding-left: 12rpx !important;
  margin-left: -12rpx;
}

/* 整体评论结构 */
.comment-body {
  flex: 1;
  min-width: 0;
}

.comment-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 4rpx;
}

.comment-avatar {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.comment-content {
  flex: 1;
}

.comment-author {
  font-size: 26rpx;
  font-weight: bold;
  color: #4A4A4A;
  display: block;
}

.comment-text {
  font-size: 26rpx;
  color: #666666;
  margin: 8rpx 0;
  display: block;
  line-height: 1.6;
}

.comment-time {
  font-size: 20rpx;
  color: #CCCCCC;
  display: block;
}

/* 回复操作按钮 */
.comment-actions {
  display: flex;
  align-items: center;
  margin-top: 6rpx;
}

.reply-btn {
  font-size: 22rpx;
  color: #FF9A6A;
  padding: 4rpx 12rpx;
  background: #FFF5EB;
  border-radius: 12rpx;
}

/* 子评论列表 */
.reply-list {
  margin-top: 12rpx;
  background: #FAFAFA;
  border-radius: 12rpx;
  padding: 12rpx 16rpx;
  border-left: 3rpx solid #FFE0CC;
}

.reply-item {
  display: flex;
  flex-direction: column;
  padding: 8rpx 0;
}

.reply-item + .reply-item {
  border-top: 1rpx solid #F0F0F0;
  padding-top: 12rpx;
  margin-top: 8rpx;
}

.reply-header {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 4rpx;
  flex-wrap: wrap;
}

.reply-avatar {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.reply-author {
  font-size: 24rpx;
  font-weight: bold;
  color: #4A4A4A;
}

.reply-connector {
  font-size: 22rpx;
  color: #999;
}

.reply-to {
  font-size: 24rpx;
  color: #FF9A6A;
  font-weight: bold;
}

.reply-text {
  font-size: 24rpx;
  color: #555;
  line-height: 1.5;
  padding-left: 48rpx;
  word-break: break-all;
}

.empty-comment {
  text-align: center;
  padding: 40rpx;
}

.empty-icon {
  font-size: 60rpx;
  display: block;
  margin-bottom: 10rpx;
}

.empty-text {
  font-size: 24rpx;
  color: #CCCCCC;
}

/* 底部评论输入 */
.comment-input-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: #ffffff;
  padding: 16rpx 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  border-top: 1rpx solid #F0F0F0;
  box-shadow: 0 -4rpx 12rpx rgba(0, 0, 0, 0.05);
}

/* 回复模式顶部提示条 */
.reply-hint-bar {
  width: 100%;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 8rpx 0 12rpx;
  border-bottom: 1rpx solid #FFE0CC;
  margin-bottom: 12rpx;
}

.reply-hint-text {
  font-size: 24rpx;
  color: #FF9A6A;
  font-weight: bold;
}

.reply-cancel {
  font-size: 24rpx;
  color: #999;
}

.input-row {
  width: 100%;
  display: flex;
  align-items: center;
}

.comment-input {
  flex: 1;
  background-color: #F5F5F5;
  border-radius: 30rpx;
  padding: 16rpx 24rpx;
  font-size: 26rpx;
}

.send-btn {
  background: linear-gradient(135deg, #FFB74D, #FF8C42);
  color: #ffffff;
  border-radius: 30rpx;
  padding: 14rpx 28rpx;
  margin-left: 16rpx;
  font-size: 26rpx;
  font-weight: bold;
}

/* 加载状态 */
.loading-page {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100vh;
  background-color: #FFF5EB;
}

.loading-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.loading-text {
  font-size: 28rpx;
  color: #999999;
}

/* ==================== 举报弹窗 ==================== */
.report-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  z-index: 999;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

.report-modal {
  background-color: #ffffff;
  border-radius: 32rpx 32rpx 0 0;
  padding: 40rpx 32rpx;
  width: 100%;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
  animation: slideUp 0.3s ease;
}

@keyframes slideUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}

.report-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  display: block;
  text-align: center;
  margin-bottom: 8rpx;
}

.report-subtitle {
  font-size: 24rpx;
  color: #999;
  display: block;
  text-align: center;
  margin-bottom: 24rpx;
}

.report-reasons {
  margin-bottom: 24rpx;
}

.report-reason-item {
  display: flex;
  align-items: center;
  padding: 24rpx 20rpx;
  border-radius: 16rpx;
  margin-bottom: 12rpx;
  background-color: #FAFAFA;
  border: 2rpx solid transparent;
  transition: all 0.2s;
}

.report-reason-item.selected {
  background-color: #FFF5EB;
  border-color: #FF9A6A;
}

.reason-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
}

.reason-text {
  flex: 1;
  font-size: 30rpx;
  color: #333;
}

.reason-check {
  font-size: 32rpx;
  color: #FF9A6A;
  font-weight: bold;
}

.report-desc {
  width: 100%;
  height: 120rpx;
  background-color: #FAFAFA;
  border-radius: 16rpx;
  padding: 16rpx 20rpx;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 24rpx;
  box-sizing: border-box;
}

.report-actions {
  display: flex;
  gap: 20rpx;
}

.report-btn {
  flex: 1;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: bold;
}

.report-cancel-btn {
  background-color: #F5F5F5;
  color: #666;
}

.report-submit-btn {
  background: linear-gradient(135deg, #FF6B6B, #EE5A24);
  color: #ffffff;
}

.report-submit-btn.disabled {
  opacity: 0.5;
}

.report-success-toast {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  background-color: rgba(0, 0, 0, 0.8);
  border-radius: 24rpx;
  padding: 32rpx 48rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  z-index: 1000;
}

.report-success-toast .toast-icon {
  font-size: 60rpx;
  margin-bottom: 12rpx;
}

.report-success-toast .toast-text {
  font-size: 28rpx;
  color: #ffffff;
}
