.page-container {
  min-height: 100vh;
  padding-bottom: 120rpx;
  background-color: #FFF5EB;
}

/* 图片轮播 */
.image-swiper {
  width: 100%;
  height: 600rpx;
}

.swiper-image {
  width: 100%;
  height: 600rpx;
}

/* 信息卡片 */
.info-card {
  margin: -40rpx 24rpx 20rpx;
  background-color: #ffffff;
  border-radius: 24rpx;
  padding: 30rpx;
  box-shadow: 0 8rpx 24rpx rgba(255, 154, 106, 0.2);
  position: relative;
  z-index: 10;
}

.info-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.avatar-row {
  display: flex;
  align-items: center;
}

.avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  margin-right: 16rpx;
  border: 3rpx solid #FFE0CC;
}

.user-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #4A4A4A;
  display: block;
}

.publish-time {
  font-size: 22rpx;
  color: #999999;
  margin-top: 6rpx;
  display: block;
}

.location-tag {
  background-color: #FFF0E0;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  color: #E67E22;
}

/* 猫咪名字区域 */
.cat-name-section {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.cat-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #6B4226;
}

.category-tag {
  padding: 8rpx 24rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
}

.category-tag.stray {
  background-color: #E8F5E9;
  color: #4CAF50;
}

.category-tag.pet {
  background-color: #E3F2FD;
  color: #2196F3;
}

.category-tag.lost {
  background-color: #FFF3E0;
  color: #FF9800;
}

/* 描述 */
.description {
  font-size: 28rpx;
  color: #666666;
  line-height: 1.8;
  word-break: break-all;
}

/* 互动区域 */
.action-bar {
  display: flex;
  margin: 20rpx 24rpx;
  background-color: #ffffff;
  border-radius: 20rpx;
  padding: 24rpx 0;
  box-shadow: 0 4rpx 12rpx rgba(255, 154, 106, 0.1);
}

.action-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
}

.action-icon {
  font-size: 40rpx;
  line-height: 1;
}

.action-icon.liked {
  animation: likeAnim 0.3s ease;
}

@keyframes likeAnim {
  0% { transform: scale(1); }
  50% { transform: scale(1.4); }
  100% { transform: scale(1); }
}

.action-text {
  font-size: 24rpx;
  color: #666666;
  line-height: 1;
}

.action-count {
  font-size: 22rpx;
  color: #999999;
  line-height: 1;
}

/* 评论区 */
.comment-section {
  margin: 20rpx 24rpx;
  background-color: #ffffff;
  border-radius: 20rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(255, 154, 106, 0.1);
}

.comment-list {
  margin-top: 20rpx;
  max-height: 600rpx;
  overflow-y: auto;
}

.comment-item {
  display: flex;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #F5F5F5;
}

.comment-item:last-child {
  border-bottom: none;
}

.comment-avatar {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.comment-content {
  flex: 1;
}

.comment-author {
  font-size: 26rpx;
  font-weight: bold;
  color: #4A4A4A;
  display: block;
}

.comment-text {
  font-size: 26rpx;
  color: #666666;
  margin: 8rpx 0;
  display: block;
  line-height: 1.6;
}

.comment-time {
  font-size: 20rpx;
  color: #CCCCCC;
  display: block;
}

.empty-comment {
  text-align: center;
  padding: 40rpx;
}

.empty-icon {
  font-size: 60rpx;
  display: block;
  margin-bottom: 10rpx;
}

.empty-text {
  font-size: 24rpx;
  color: #CCCCCC;
}

/* 底部评论输入 */
.comment-input-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: #ffffff;
  padding: 16rpx 24rpx;
  display: flex;
  align-items: center;
  border-top: 1rpx solid #F0F0F0;
  box-shadow: 0 -4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.comment-input {
  flex: 1;
  background-color: #F5F5F5;
  border-radius: 30rpx;
  padding: 16rpx 24rpx;
  font-size: 26rpx;
}

.send-btn {
  background: linear-gradient(135deg, #FFB74D, #FF8C42);
  color: #ffffff;
  border-radius: 30rpx;
  padding: 14rpx 28rpx;
  margin-left: 16rpx;
  font-size: 26rpx;
  font-weight: bold;
}

/* 加载状态 */
.loading-page {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100vh;
  background-color: #FFF5EB;
}

.loading-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.loading-text {
  font-size: 28rpx;
  color: #999999;
}
