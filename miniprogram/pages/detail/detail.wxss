  padding: 10rpx 28rpx;
  border-radius: 40rpx;
  font-size: 26rpx;
  font-weight: 600;
  background: #FF7043;
  color: #fff;
  border: none;
  white-space: nowrap;
}

.follow-btn.following {
  background: #f5f5f5;
  color: #999;
}

/* 图片轮播 */
.image-swiper {
  width: 100%;
  height: 600rpx;
}

/* 轮播容器与切换指示器样式。 */
.swiper-image {
  width: 100%;
  height: 600rpx;
}

/* 发布者信息 */
.author-section {
  margin: -40rpx 24rpx 20rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(255, 154, 106, 0.2);
  position: relative;
  z-index: 10;
}
.author-info-row {
  display: flex;
  align-items: center;
}
.author-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  margin-right: 16rpx;
  border: 3rpx solid #FFE4C4;
  background: #f0f0f0;
}
.author-details {
  flex: 1;
}
.author-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  display: block;
}
/* 帖子内容、图片和互动区样式。 */
.post-time {
  font-size: 22rpx;
  color: #bbb;
  margin-top: 4rpx;
  display: block;
}
/* 定位标签与地点信息样式。 */
.location-tag {
  background-color: #fff0e0;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  color: #E67E22;
  display: inline-block;
  margin-top: 12rpx;
}

/* 分类标签 */
.category-section {
  margin: 0 24rpx 20rpx;
}
.category-tag {
  display: inline-block;
  background: #FFF0E0;
  color: #FF9A6A;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: 500;
}

/* 关联猫咪卡片 */
.cat-card {
  margin: 0 24rpx 20rpx;
  background: linear-gradient(135deg, #FFF5EB, #FFE8D6);
  border-radius: 24rpx;
  padding: 20rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 4rpx 12rpx rgba(255, 154, 106, 0.15);
}
/* 猫咪资料、头像和标签样式。 */
.cat-cover {
  width: 100rpx;
  height: 100rpx;
  border-radius: 16rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
  background: #fff;
}
.cat-info {
  flex: 1;
}
.cat-name-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 6rpx;
}
.cat-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #6b4226;
}
.cat-type-badge {
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
  font-size: 20rpx;
  font-weight: bold;
}
.cat-type-badge.formal { background: #FF9A6A; color: #fff; }
.cat-type-badge.unknown { background: #88BBFF; color: #fff; }
.cat-meta {
  font-size: 22rpx;
  color: #999;
  display: block;
  margin-top: 4rpx;
}
.cat-stats {
  font-size: 22rpx;
  color: #FF7043;
  margin-top: 6rpx;
}
.cat-arrow {
  font-size: 40rpx;
  color: #FF9A6A;
  margin-left: 12rpx;
}

/* 帖子内容 */
.post-content-section {
  margin: 0 24rpx 20rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(255, 154, 106, 0.1);
}
/* 帖子内容、图片和互动区样式。 */
.post-text {
  font-size: 30rpx;
  color: #333;
  line-height: 1.8;
  word-break: break-all;
}

/* 分享按钮重置 */
.share-btn {
  background: transparent !important;
  border: none !important;
  padding: 0 !important;
  margin: 0 !important;
  line-height: normal !important;
}
.share-btn::after { border: none; }

/* 互动区域 */
.action-bar {
  display: flex;
  margin: 20rpx 24rpx;
  background-color: #ffffff;
  border-radius: 20rpx;
  padding: 24rpx 0;
  box-shadow: 0 4rpx 12rpx rgba(255, 154, 106, 0.1);
}

/* 操作按钮与功能入口样式。 */
.action-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
}

.action-icon {
  font-size: 40rpx;
  line-height: 1;
}

.action-icon.liked {
  animation: likeAnim 0.3s ease;
}

/* 动效关键帧定义。 */
@keyframes likeAnim {
  0% {
    transform: scale(1);
  }
  50% {
    transform: scale(1.4);
  }
  100% {
    transform: scale(1);
  }
}

/* 操作按钮与功能入口样式。 */
.action-text {
  font-size: 24rpx;
  color: #666666;
  line-height: 1;
}

.action-count {
  font-size: 22rpx;
  color: #999999;
  line-height: 1;
}

.detail-ad-section {
  margin: 20rpx 24rpx;
  padding: 20rpx 20rpx 12rpx;
  background: #ffffff;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(255, 154, 106, 0.1);
}

.detail-ad-label {
  font-size: 22rpx;
  color: #b08a6a;
  margin-bottom: 12rpx;
}

/* 评论区 */
.comment-section {
  margin: 20rpx 24rpx;
  background-color: #ffffff;
  border-radius: 20rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(255, 154, 106, 0.1);
}

/* 评论区与回复区样式。 */
.comment-list {
  margin-top: 20rpx;
  max-height: 600rpx;
  overflow-y: auto;
}

.comment-item {
  display: flex;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.comment-item:last-child {
  border-bottom: none;
}

/* 未读评论左侧竖线 */
.comment-unread {
  border-left: 4rpx solid #FF9A6A;
  padding-left: 12rpx !important;
  margin-left: -12rpx;
}

/* 整体评论结构 */
.comment-body {
  flex: 1;
  min-width: 0;
}

.comment-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 4rpx;
}

.comment-avatar {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.comment-content {
  flex: 1;
}

.comment-author {
  font-size: 26rpx;
  font-weight: bold;
  color: #4a4a4a;
  display: block;
}

.comment-text {
  font-size: 26rpx;
  color: #666666;
  margin: 8rpx 0;
  display: block;
  line-height: 1.6;
}

.comment-attachments {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin: 10rpx 0 4rpx;
}

.comment-attachment-item {
  width: 160rpx;
  height: 160rpx;
  border-radius: 18rpx;
  background: #f5f5f5;
}

.comment-attachment-item.small {
  width: 128rpx;
  height: 128rpx;
  border-radius: 16rpx;
}

.comment-time {
  font-size: 20rpx;
  color: #cccccc;
  display: block;
}

/* 回复操作按钮 */
.comment-actions {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 12rpx;
  margin-top: 6rpx;
}

/* 回复态、引用态与子评论样式。 */
.reply-btn {
  font-size: 22rpx;
  color: #FF9A6A;
  padding: 4rpx 12rpx;
  background: #FFF5EB;
  border-radius: 12rpx;
}
/* 评论区与回复区样式。 */
.comment-like {
  font-size: 22rpx;
  color: #999;
  padding: 4rpx 12rpx;
  background: #F7F7F7;
  border-radius: 12rpx;
}

.comment-like.liked {
  color: #FF7043;
  background: #FFF0E8;
}
/* 子评论列表 */
.reply-list {
  margin-top: 12rpx;
  background: #FAFAFA;
  border-radius: 12rpx;
  padding: 12rpx 16rpx;
  border-left: 3rpx solid #FFE0CC;
}

/* 回复态、引用态与子评论样式。 */
.reply-item {
  display: flex;
  flex-direction: column;
  padding: 8rpx 0;
}

.reply-item + .reply-item {
  border-top: 1rpx solid #F0F0F0;
  padding-top: 12rpx;
  margin-top: 8rpx;
}

.reply-header {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 4rpx;
  flex-wrap: wrap;
}

.reply-avatar {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.reply-author {
  font-size: 24rpx;
  font-weight: bold;
  color: #4A4A4A;
}

.reply-connector {
  font-size: 22rpx;
  color: #999;
}

.reply-to {
  font-size: 24rpx;
  color: #FF9A6A;
  font-weight: bold;
}

.reply-text {
  font-size: 24rpx;
  color: #555;
  line-height: 1.5;
  padding-left: 48rpx;
  word-break: break-all;
}

.reply-attachments {
  padding-left: 48rpx;
}

.reply-actions {
  display: flex;
  justify-content: flex-end;
  padding-left: 48rpx;
  margin-top: 6rpx;
}
/* 空状态提示与占位样式。 */
.empty-comment {
  text-align: center;
  padding: 40rpx;
}

.empty-icon {
  font-size: 60rpx;
  display: block;
  margin-bottom: 10rpx;
}

.empty-text {
  font-size: 24rpx;
  color: #cccccc;
}

/* 底部评论输入 */
.comment-input-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: #ffffff;
  padding: 16rpx 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  border-top: 1rpx solid #f0f0f0;
  box-shadow: 0 -4rpx 12rpx rgba(0, 0, 0, 0.05);
  z-index: 30;
}

/* 回复模式顶部提示条 */
.reply-hint-bar {
  width: 100%;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 8rpx 0 12rpx;
  border-bottom: 1rpx solid #FFE0CC;
  margin-bottom: 12rpx;
}

/* 回复态、引用态与子评论样式。 */
.reply-hint-text {
  font-size: 24rpx;
  color: #FF9A6A;
  font-weight: bold;
}

.reply-cancel {
  font-size: 24rpx;
  color: #999;
}

/* 输入控件与编辑态样式。 */
.input-row {
  width: 100%;
  display: flex;
  align-items: center;
}

.composer-tool-btn {
  width: 68rpx;
  height: 68rpx;
  border-radius: 50%;
  background: #fff5eb;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 12rpx;
  font-size: 30rpx;
  color: #ff8c42;
  flex-shrink: 0;
}

/* 评论区与回复区样式。 */
.comment-input {
  flex: 1;
  background-color: #f5f5f5;
  border-radius: 30rpx;
  padding: 16rpx 24rpx;
  font-size: 26rpx;
  min-width: 0;
}

.send-btn {
  background: linear-gradient(135deg, #ffb74d, #ff8c42);
  color: #ffffff;
  border-radius: 30rpx;
  padding: 14rpx 28rpx;
  margin-left: 16rpx;
  font-size: 26rpx;
  font-weight: bold;
}

.send-btn.disabled {
  opacity: 0.65;
}

.selected-attachment-list {
  width: 100%;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 14rpx;
}

.selected-attachment-item {
  position: relative;
  width: 132rpx;
  height: 132rpx;
  border-radius: 18rpx;
  overflow: hidden;
  background: #f7f7f7;
}

.selected-attachment-image {
  width: 100%;
  height: 100%;
}

.selected-attachment-badge {
  position: absolute;
  left: 8rpx;
  bottom: 8rpx;
  padding: 4rpx 10rpx;
  border-radius: 12rpx;
  background: rgba(0, 0, 0, 0.58);
  color: #fff;
  font-size: 18rpx;
  line-height: 1.2;
}

.selected-attachment-remove {
  position: absolute;
  top: 6rpx;
  right: 6rpx;
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.55);
  color: #fff;
  font-size: 26rpx;
  line-height: 36rpx;
  text-align: center;
}

.composer-panel {
  width: 100%;
  margin-top: 16rpx;
  padding: 20rpx;
  border-radius: 24rpx;
  background: #fff8f1;
  box-sizing: border-box;
}

.composer-panel-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.composer-panel-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #6b4226;
}

.panel-add-btn {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: #ffefe0;
  color: #ff8c42;
  font-size: 22rpx;
  white-space: nowrap;
}

.emoji-grid {
  display: grid;
  grid-template-columns: repeat(6, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: 16rpx;
}

.emoji-item {
  height: 72rpx;
  border-radius: 18rpx;
  background: #fff;
  text-align: center;
  line-height: 72rpx;
  font-size: 36rpx;
}

.sticker-block {
  margin-top: 16rpx;
}

.sticker-block-title {
  display: block;
  margin-bottom: 12rpx;
  font-size: 22rpx;
  color: #9a7b61;
}

.sticker-grid {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 12rpx;
}

.sticker-item {
  width: 100%;
  aspect-ratio: 1 / 1;
  border-radius: 18rpx;
  background: #fff;
}

.sticker-empty {
  padding: 24rpx 0;
  text-align: center;
  color: #b08a6a;
  font-size: 22rpx;
}

/* 加载状态 */
.loading-page {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100vh;
  background-color: #fff5eb;
}

/* 加载提示与状态反馈样式。 */
.loading-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.loading-text {
  font-size: 28rpx;
  color: #999999;
}

/* ==================== 举报弹窗 ==================== */
.report-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  z-index: 999;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

/* 举报弹层与反馈结果样式。 */
.report-modal {
  background-color: #ffffff;
  border-radius: 32rpx 32rpx 0 0;
  padding: 40rpx 32rpx;
  width: 100%;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
  animation: slideUp 0.3s ease;
}

/* 动效关键帧定义。 */
@keyframes slideUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}

/* 举报弹层与反馈结果样式。 */
.report-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  display: block;
  text-align: center;
  margin-bottom: 8rpx;
}

.report-subtitle {
  font-size: 24rpx;
  color: #999;
  display: block;
  text-align: center;
  margin-bottom: 24rpx;
}

.report-reasons {
  margin-bottom: 24rpx;
}

.report-reason-item {
  display: flex;
  align-items: center;
  padding: 24rpx 20rpx;
  border-radius: 16rpx;
  margin-bottom: 12rpx;
  background-color: #FAFAFA;
  border: 2rpx solid transparent;
  transition: all 0.2s;
}

.report-reason-item.selected {
  background-color: #FFF5EB;
  border-color: #FF9A6A;
}

.reason-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
}

.reason-text {
  flex: 1;
  font-size: 30rpx;
  color: #333;
}

.reason-check {
  font-size: 32rpx;
  color: #FF9A6A;
  font-weight: bold;
}

/* 举报弹层与反馈结果样式。 */
.report-desc {
  width: 100%;
  height: 120rpx;
  background-color: #FAFAFA;
  border-radius: 16rpx;
  padding: 16rpx 20rpx;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 24rpx;
  box-sizing: border-box;
}

.report-actions {
  display: flex;
  gap: 20rpx;
}

.report-btn {
  flex: 1;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: bold;
}

.report-cancel-btn {
  background-color: #F5F5F5;
  color: #666;
}

.report-submit-btn {
  background: linear-gradient(135deg, #FF6B6B, #EE5A24);
  color: #ffffff;
}

.report-submit-btn.disabled {
  opacity: 0.5;
}

.report-success-toast {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  background-color: rgba(0, 0, 0, 0.8);
  border-radius: 24rpx;
  padding: 32rpx 48rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  z-index: 1000;
}

.report-success-toast .toast-icon {
  font-size: 60rpx;
  margin-bottom: 12rpx;
}

.report-success-toast .toast-text {
  font-size: 28rpx;
  color: #ffffff;
}
