.page-container {
  min-height: 100vh;
  background-color: #FFF5EB;
}

/* 用户信息头部 */
.profile-header {
  position: relative;
  overflow: hidden;
}

.header-bg {
  height: 240rpx;
  background: linear-gradient(135deg, #FFE0CC 0%, #FFD4B8 50%, #FFC9A8 100%);
}

.header-bg::before {
  content: '🐾';
  position: absolute;
  right: 40rpx;
  top: 30rpx;
  font-size: 60rpx;
  opacity: 0.3;
}

.header-bg::after {
  content: '🐱';
  position: absolute;
  left: 30rpx;
  top: 20rpx;
  font-size: 80rpx;
  opacity: 0.25;
}

.user-card {
  position: relative;
  margin: -80rpx 30rpx 0;
  background-color: #ffffff;
  border-radius: 24rpx;
  padding: 40rpx 30rpx 30rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 8rpx 24rpx rgba(255, 154, 106, 0.2);
}

.user-avatar {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  border: 6rpx solid #FFE0CC;
  margin-bottom: 16rpx;
}

/* 登录相关 */
.login-avatar-wrap {
  position: relative;
  margin-bottom: 16rpx;
}
.login-badge {
  position: absolute;
  bottom: 0; right: -10rpx;
  background: #FF9A6A; color: #fff;
  padding: 4rpx 16rpx; border-radius: 16rpx;
  font-size: 20rpx; font-weight: bold;
}
.avatar-btn {
  background: transparent !important;
  border: none !important;
  padding: 0 !important;
  margin: 0 !important;
  line-height: normal !important;
  width: 140rpx !important;
  height: 140rpx !important;
}
.avatar-btn::after { border: none; }
.avatar-btn .user-avatar { margin-bottom: 0; }

.user-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #4A4A4A;
  margin-bottom: 8rpx;
}

.user-desc {
  font-size: 24rpx;
  color: #999999;
}

/* 统计数据 */
.stats-card {
  display: flex;
  margin: 24rpx 30rpx;
  background-color: #ffffff;
  border-radius: 20rpx;
  padding: 30rpx 0;
  box-shadow: 0 4rpx 12rpx rgba(255, 154, 106, 0.1);
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-num {
  font-size: 40rpx;
  font-weight: bold;
  color: #FF8C42;
}

.stat-label {
  font-size: 24rpx;
  color: #999999;
  margin-top: 8rpx;
}

.stat-divider {
  width: 2rpx;
  background-color: #F0F0F0;
  margin: 10rpx 0;
}

/* 菜单卡片 */
.menu-card {
  margin: 20rpx 30rpx;
  background-color: #ffffff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(255, 154, 106, 0.1);
}

.menu-title {
  padding: 24rpx 30rpx 16rpx;
  font-size: 28rpx;
  font-weight: bold;
  color: #6B4226;
}

.menu-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 30rpx;
  border-top: 1rpx solid #F5F5F5;
}

.menu-item:active {
  background-color: #FFF5EB;
}

.menu-left {
  display: flex;
  align-items: center;
}

.menu-icon {
  font-size: 36rpx;
  margin-right: 16rpx;
}

.menu-text {
  font-size: 28rpx;
  color: #4A4A4A;
}

.menu-arrow {
  font-size: 36rpx;
  color: #CCCCCC;
}

/* 版本信息 */
.version-info {
  text-align: center;
  padding: 40rpx 0 60rpx;
}

.version-info text {
  display: block;
  font-size: 22rpx;
  color: #CCCCCC;
  margin-bottom: 8rpx;
}

.version-sub {
  color: #FFD4B8 !important;
}
