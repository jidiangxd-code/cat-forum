<!--个人中心-->
<view class="page-container">
  <!-- 用户信息头部 -->
  <view class="profile-header">
    <view class="header-bg"></view>
    <view class="user-card">
      <!-- 未登录：显示登录按钮 -->
      <block wx:if="{{!isLoggedIn}}">
        <view class="login-avatar-wrap" bindtap="doLogin">
          <image class="user-avatar" src="/assets/images/default-avatar.png" mode="aspectFill" />
          <view class="login-badge">登录</view>
        </view>
        <text class="user-name">点击登录</text>
        <text class="user-desc">登录后即可发布和评论 🐱</text>
      </block>
      <!-- 已登录：显示用户信息 -->
      <block wx:else>
        <button class="avatar-btn" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
          <image class="user-avatar" src="{{avatarError ? '/assets/images/default-avatar.png' : (userInfo.avatarUrl || '/assets/images/default-avatar.png')}}" mode="aspectFill" binderror="onAvatarError" />
        </button>
        <text class="user-name">{{userInfo.nickName || '爱猫同学'}}</text>
        <text class="user-desc">🐱 校园猫咪守护者</text>
      </block>
    </view>
  </view>

  <!-- 统计数据 -->
  <view class="stats-card">
    <view class="stat-item">
      <text class="stat-num">{{stats.publishCount}}</text>
      <text class="stat-label">发布</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item">
      <text class="stat-num">{{stats.likeCount}}</text>
      <text class="stat-label">获赞</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item">
      <text class="stat-num">{{stats.favCount}}</text>
      <text class="stat-label">收藏</text>
    </view>
  </view>

  <!-- 消息通知 -->
  <view class="menu-card" wx:if="{{isLoggedIn}}">
    <view class="menu-title">
      <text>🔔 消息</text>
    </view>
    <view class="menu-item" bindtap="goToNotifications">
      <view class="menu-left">
        <text class="menu-icon">🔔</text>
        <text class="menu-text">消息通知</text>
      </view>
      <view class="menu-right">
        <text class="badge" wx:if="{{unreadCount > 0}}">{{unreadCount > 99 ? '99+' : unreadCount}}</text>
        <text class="menu-arrow">›</text>
      </view>
    </view>
  </view>

  <!-- 功能菜单 -->
  <view class="menu-card">
    <view class="menu-title">
      <text>📋 我的内容</text>
    </view>
    <view class="menu-item" bindtap="{{isLoggedIn ? 'goToMyPosts' : 'doLogin'}}">
      <view class="menu-left">
        <text class="menu-icon">📝</text>
        <text class="menu-text">我的发布</text>
      </view>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="{{isLoggedIn ? 'goToMyLikes' : 'doLogin'}}">
      <view class="menu-left">
        <text class="menu-icon">❤️</text>
        <text class="menu-text">我喜欢的</text>
      </view>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="{{isLoggedIn ? 'goToMyComments' : 'doLogin'}}">
      <view class="menu-left">
        <text class="menu-icon">💬</text>
        <text class="menu-text">我的评论</text>
      </view>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="{{isLoggedIn ? 'goToMyFavorites' : 'doLogin'}}">
      <view class="menu-left">
        <text class="menu-icon">⭐</text>
        <text class="menu-text">我的收藏</text>
      </view>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <!-- 关注管理 -->
  <view class="menu-card" wx:if="{{isLoggedIn}}">
    <view class="menu-title">
      <text>👥 社交</text>
    </view>
    <view class="menu-item" bindtap="{{isLoggedIn ? 'goToMyFollows' : 'doLogin'}}">
      <view class="menu-left">
        <text class="menu-icon">❤️‍🔥</text>
        <text class="menu-text">我的关注</text>
      </view>
      <view class="menu-right">
        <text class="menu-arrow">›</text>
      </view>
    </view>
    <view class="menu-item" bindtap="{{isLoggedIn ? 'goToMyFollowers' : 'doLogin'}}">
      <view class="menu-left">
        <text class="menu-icon">👥</text>
        <text class="menu-text">我的粉丝</text>
      </view>
      <view class="menu-right">
        <text class="menu-arrow">›</text>
      </view>
    </view>
  </view>

  <!-- 设置菜单 -->
  <view class="menu-card">
    <view class="menu-title">
      <text>⚙️ 设置</text>
    </view>
    <view class="menu-item" bindtap="{{isLoggedIn ? 'editProfile' : 'doLogin'}}">
      <view class="menu-left">
        <text class="menu-icon">👤</text>
        <text class="menu-text">编辑资料</text>
      </view>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="clearCache">
      <view class="menu-left">
        <text class="menu-icon">🗑️</text>
        <text class="menu-text">清除缓存</text>
      </view>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="toggleDarkMode">
      <view class="menu-left">
        <text class="menu-icon">{{isDarkMode ? '☀️' : '🌙'}}</text>
        <text class="menu-text">{{isDarkMode ? '切换亮色模式' : '切换深色模式'}}</text>
      </view>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="aboutUs">
      <view class="menu-left">
        <text class="menu-icon">ℹ️</text>
        <text class="menu-text">关于我们</text>
      </view>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <!-- 版本号 -->
  <view class="version-info">
    <text>校园小猫论坛 v1.0.0</text>
    <text class="version-sub">用爱守护每一只校园小猫 🐾</text>
  </view>
</view>
