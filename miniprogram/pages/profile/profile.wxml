<!--个人中心 - 带Tab切换 + 主题选择-->
<view class="{{pageClass}}">
  <!-- 用户信息头部 -->
  <view class="profile-header">
    <view class="header-bg"></view>
    <view class="user-card">
      <!-- 未登录：显示登录按钮 -->
      <block wx:if="{{!isLoggedIn}}">
        <view class="login-avatar-wrap" bindtap="doLogin">
          <image class="user-avatar" src="/assets/images/default-avatar.png" mode="aspectFill" />
          <view class="login-badge">登录</view>
        </view>
        <text class="user-name">点击登录</text>
        <text class="user-desc">登录后即可发布和评论 🐱</text>
      </block>
      <!-- 已登录：纯展示用户信息 -->
      <block wx:else>
        <image class="user-avatar" src="{{userInfo.avatarUrl || '/assets/images/default-avatar.png'}}" mode="aspectFill" binderror="onAvatarError" />
        <text class="user-name">{{userInfo.nickName || '爱猫同学'}}</text>
        <view class="user-tags">
          <text class="user-tag" wx:if="{{userInfo.gender}}">{{userInfo.gender === 'male' ? '♂ 男' : userInfo.gender === 'female' ? '♀ 女' : '⚪ 保密'}}</text>
          <text class="user-tag" wx:if="{{userInfo.campus}}">🏫 {{userInfo.campus}}</text>
        </view>
        <text class="user-desc">{{userInfo.bio || '🐱 校园猫咪守护者'}}</text>
      </block>
    </view>
  </view>

  <!-- 统计数据 -->
  <view class="stats-card">
    <view class="stat-item">
      <text class="stat-num">{{stats.publishCount}}</text>
      <text class="stat-label">发布</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item">
      <text class="stat-num">{{stats.likeCount}}</text>
      <text class="stat-label">获赞</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item">
      <text class="stat-num">{{stats.favCount}}</text>
      <text class="stat-label">收藏</text>
    </view>
  </view>

  <!-- 主题选择 -->
  <view class="theme-card">
    <view class="theme-title">🎨 主题皮肤</view>
    <view class="theme-list">
      <view
        class="theme-item {{themeId === item.id ? 'active' : ''}}"
        wx:for="{{themeOptions}}"
        wx:key="id"
        bindtap="switchTheme"
        data-id="{{item.id}}"
      >
        <view class="theme-swatch theme-swatch-{{item.id}}"></view>
        <text class="theme-name">{{item.icon}} {{item.name}}</text>
        <text class="theme-check" wx:if="{{themeId === item.id}}">✓</text>
      </view>
    </view>
  </view>

  <!-- Tab 切换栏 -->
  <view class="tab-bar" wx:if="{{isLoggedIn}}">
    <view 
      class="tab-item {{currentTab === item.key ? 'active' : ''}}"
      wx:for="{{tabs}}"
      wx:key="key"
      bindtap="switchTab"
      data-tab="{{item.key}}"
    >
      <text class="tab-icon">{{item.icon}}</text>
      <text class="tab-text">{{item.label}}</text>
    </view>
  </view>

  <!-- Tab 内容区 -->
  <view class="tab-content" wx:if="{{isLoggedIn}}">
    <!-- 加载中 -->
    <view class="tab-loading" wx:if="{{tabLoading[currentTab]}}">
      <text class="loading-icon">🐾</text>
      <text>加载中...</text>
    </view>

    <!-- 空状态 -->
    <view class="tab-empty" wx:elif="{{tabEmpty[currentTab]}}">
      <text class="empty-icon">📝</text>
      <text class="empty-text">暂无内容</text>
      <text class="empty-hint">快去探索精彩内容吧～</text>
    </view>

    <!-- 列表内容 -->
    <scroll-view scroll-y class="tab-list" wx:else>
      <!-- 我的发布 -->
      <block wx:if="{{currentTab === 'posts'}}">
        <view class="post-item" wx:for="{{tabData.posts}}" wx:key="_id" bindtap="onPostTap" data-id="{{item._id}}">
          <image class="post-cover" src="{{item.images[0] || '/assets/images/default-cat.png'}}" mode="aspectFill" />
          <view class="post-info">
            <text class="post-title">{{item.content}}</text>
            <view class="post-meta">
              <text class="post-time">{{item.timeStr}}</text>
              <text class="post-count">❤️ {{item.likeCount || 0}}</text>
            </view>
          </view>
        </view>
      </block>

      <!-- 我喜欢的 -->
      <block wx:if="{{currentTab === 'likes'}}">
        <view class="post-item" wx:for="{{tabData.likes}}" wx:key="_id" bindtap="onPostTap" data-id="{{item._id}}">
          <image class="post-cover" src="{{item.images[0] || '/assets/images/default-cat.png'}}" mode="aspectFill" />
          <view class="post-info">
            <text class="post-title">{{item.content}}</text>
            <view class="post-meta">
              <text class="post-time">{{item.timeStr}}</text>
              <text class="post-count">❤️ {{item.likeCount || 0}}</text>
            </view>
          </view>
        </view>
      </block>

      <!-- 我的评论 -->
      <block wx:if="{{currentTab === 'comments'}}">
        <view class="comment-item" wx:for="{{tabData.comments}}" wx:key="_id" bindtap="onPostTap" data-id="{{item.postId}}">
          <text class="comment-text">{{item.content}}</text>
          <view class="comment-meta">
            <text class="comment-time">{{item.timeStr}}</text>
            <text class="comment-post">查看原帖 ›</text>
          </view>
        </view>
      </block>

      <!-- 我的收藏 -->
      <block wx:if="{{currentTab === 'favorites'}}">
        <view class="post-item" wx:for="{{tabData.favorites}}" wx:key="_id" bindtap="onPostTap" data-id="{{item._id}}">
          <image class="post-cover" src="{{item.images[0] || '/assets/images/default-cat.png'}}" mode="aspectFill" />
          <view class="post-info">
            <text class="post-title">{{item.content}}</text>
            <view class="post-meta">
              <text class="post-time">{{item.timeStr}}</text>
              <view class="post-actions">
                <text class="post-count">❤️ {{item.likeCount || 0}}</text>
                <text class="unfav-btn" catchtap="unfavorite" data-id="{{item._id}}">取消收藏</text>
              </view>
            </view>
          </view>
        </view>
      </block>
    </scroll-view>
  </view>

  <!-- 未登录提示 -->
  <view class="login-prompt" wx:if="{{!isLoggedIn}}">
    <text class="prompt-icon">🔒</text>
    <text class="prompt-text">登录后查看我的内容</text>
    <view class="prompt-btn" bindtap="doLogin">立即登录</view>
  </view>

  <!-- 设置菜单 -->
  <view class="menu-card" wx:if="{{isLoggedIn}}">
    <view class="menu-item" bindtap="editProfile">
      <view class="menu-left">
        <text class="menu-icon">👤</text>
        <text class="menu-text">编辑资料</text>
      </view>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="clearCache">
      <view class="menu-left">
        <text class="menu-icon">🗑️</text>
        <text class="menu-text">清除缓存</text>
      </view>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="aboutUs">
      <view class="menu-left">
        <text class="menu-icon">ℹ️</text>
        <text class="menu-text">关于我们</text>
      </view>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <!-- 版本号 -->
  <view class="version-info">
    <text>校园小猫论坛 v1.0.0</text>
    <text class="version-sub">用爱守护每一只校园小猫 🐾</text>
  </view>
</view>
