<!-- pages/index/index.wxml - 首页（帖子流）-->
<view class="{{pageClass}}">

  <!-- 顶部横幅（渐变色跟随主题）-->
  <view class="banner">
    <view class="banner-left">
      <text class="banner-title">🐾 校园小猫</text>
      <text class="banner-sub">发现每一只可爱的猫咪</text>
    </view>
    <view class="banner-right">
      <view class="cat-rank-btn" bindtap="goCatList">猫咪榜 🏆</view>
      <view class="search-btn" bindtap="goSearch">🔍</view>
    </view>
  </view>

  <!-- 帖子流 -->
  <view class="post-list">
    <view class="post-card" wx:for="{{postList}}" wx:key="_id">

      <!-- 发布者信息 -->
      <view class="post-author" bindtap="onPostTap" data-id="{{item._id}}">
        <image
          class="author-avatar"
          src="{{item.authorAvatar || '/assets/images/default-avatar.png'}}"
          mode="aspectFill"
        />
        <view class="author-info">
          <text class="author-name">{{item.authorName || '匿名用户'}}</text>
          <text class="post-time">{{item.createTimeStr}}</text>
        </view>
        <view class="post-category-tag" wx:if="{{item.category}}">
          {{categoryMap[item.category] || item.category}}
        </view>
      </view>

      <!-- 图片组 -->
      <view
        class="post-imgs"
        wx:if="{{item.images && item.images.length > 0}}"
        bindtap="onPostTap"
        data-id="{{item._id}}"
      >
        <image
          wx:for="{{item.images}}"
          wx:for-item="img"
          wx:key="index"
          wx:if="{{index < 3}}"
          class="post-img {{item.images.length === 1 ? 'single' : ''}}"
          src="{{img}}"
          mode="aspectFill"
          catchtap="previewImage"
          data-images="{{item.images}}"
          data-index="{{index}}"
        />
        <view class="img-more-badge" wx:if="{{item.images.length > 3}}">+{{item.images.length - 3}}</view>
      </view>

      <!-- 文字内容 -->
      <view class="post-content" bindtap="onPostTap" data-id="{{item._id}}">
        <text class="post-text">{{item.content}}</text>
      </view>

      <!-- 底部：关联猫咪 + 点赞 -->
      <view class="post-footer">
        <!-- 关联猫咪（可点击跳转） -->
        <view
          class="cat-tag"
          wx:if="{{item.cat}}"
          catchtap="onCatTap"
          data-catid="{{item.catId}}"
        >
          <text class="cat-icon">🐱</text>
          <text class="cat-name">{{item.cat.fullName || item.cat.codeName}}</text>
          <text class="cat-arrow">›</text>
        </view>
        <view class="cat-tag cat-empty" wx:else>
          <text class="cat-icon">🐱</text>
          <text class="cat-name">未知猫咪</text>
        </view>

        <!-- 点赞 -->
        <view
          class="like-btn {{item.liked ? 'liked' : ''}}"
          catchtap="onLike"
          data-id="{{item._id}}"
          data-liked="{{item.liked}}"
        >
          <text>{{item.liked ? '❤️' : '🤍'}} {{item.likeCount || 0}}</text>
        </view>
      </view>

    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty" wx:if="{{!loading && postList.length === 0}}">
    <text class="empty-icon">🐾</text>
    <text class="empty-text">还没有帖子，快去发布第一只猫咪吧！</text>
    <view class="empty-btn" bindtap="goPublish">去发布</view>
  </view>

  <view class="load-more" wx:if="{{loading && postList.length > 0}}">加载中...</view>
  <view class="no-more" wx:elif="{{!hasMore && postList.length > 0}}">— 到底了 🐱 —</view>

</view>
