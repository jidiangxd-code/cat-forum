/* pages/index/index.wxss - 首页样式（已迁移到 CSS 变量）*/
.page { background: var(--color-bg); min-height: 100vh; }

/* 顶部横幅 */
.banner {
  background: var(--banner-gradient);
  padding: 24rpx 28rpx;
  display: flex; align-items: center; justify-content: space-between;
}
.banner-title { display: block; font-size: 36rpx; font-weight: bold; color: var(--color-text-white); }
.banner-sub { display: block; font-size: 22rpx; color: rgba(255,255,255,0.8); margin-top: 4rpx; }
.cat-rank-btn {
  background: rgba(255,255,255,0.2); color: var(--color-text-white);
  padding: 12rpx 24rpx; border-radius: 30rpx; font-size: 24rpx;
}
.search-btn {
  font-size: 32rpx;
  padding: 12rpx 16rpx;
}

/* 帖子流 */
.post-list { padding: 16rpx 0; }
.post-card {
  background: var(--color-bg-card); margin: 0 0 16rpx;
}

/* 发布者信息 */
.post-author {
  display: flex; align-items: center; padding: 20rpx 24rpx 12rpx;
}
.author-avatar {
  width: 64rpx; height: 64rpx; border-radius: 50%; margin-right: 16rpx;
  overflow: hidden; flex-shrink: 0; background: var(--color-bg-image);
}
.author-info { flex: 1; }
.author-name { display: block; font-size: 28rpx; font-weight: 500; color: var(--color-text-primary); }
.post-time { font-size: 22rpx; color: var(--color-text-desc); margin-top: 4rpx; }

/* 分类标签 */
.post-category-tag {
  padding: 6rpx 16rpx; border-radius: 12rpx;
  background: var(--color-bg-tag); color: var(--color-text-accent); font-size: 22rpx;
}

/* 帖子图片 */
.post-imgs {
  display: flex; gap: 4rpx; position: relative;
  background: var(--color-bg-image); max-height: 500rpx; overflow: hidden;
}
.post-img { flex: 1; height: 400rpx; min-width: 0; }
.post-img.single { height: 480rpx; }
.img-more-badge {
  position: absolute; right: 8rpx; bottom: 8rpx;
  background: rgba(0,0,0,0.5); color: var(--color-text-white);
  padding: 8rpx 16rpx; border-radius: 20rpx; font-size: 24rpx;
}

/* 文字内容 */
.post-content { padding: 16rpx 24rpx 12rpx; }
.post-text {
  font-size: 28rpx; color: var(--color-text-primary); line-height: 1.7;
  display: -webkit-box; -webkit-box-orient: vertical;
  -webkit-line-clamp: 4; overflow: hidden;
}

/* 底部 */
.post-footer {
  display: flex; align-items: center; justify-content: space-between;
  padding: 0 24rpx 20rpx;
}

/* 关联猫咪标签 */
.cat-tag {
  display: flex; align-items: center;
  padding: 8rpx 16rpx; border-radius: 20rpx;
  background: var(--color-bg); border: 1rpx solid var(--color-border);
}
.cat-tag.cat-empty {
  background: var(--color-bg-disabled); border-color: var(--color-border);
}
.cat-icon { font-size: 24rpx; margin-right: 8rpx; }
.cat-name { font-size: 24rpx; color: var(--color-text-accent); font-weight: 500; }
.cat-tag.cat-empty .cat-name { color: var(--color-text-secondary); }
.cat-arrow { font-size: 24rpx; color: var(--color-text-accent); margin-left: 4rpx; }

.like-btn { font-size: 26rpx; color: var(--color-text-secondary); padding: 8rpx 16rpx; }
.like-btn.liked { color: var(--color-text-accent); }

/* 空状态 */
.empty {
  display: flex; flex-direction: column; align-items: center;
  padding: 120rpx 40rpx;
}
.empty-icon { font-size: 80rpx; margin-bottom: 20rpx; }
.empty-text { font-size: 28rpx; color: var(--color-text-secondary); margin-bottom: 32rpx; text-align: center; }
.empty-btn {
  background: var(--color-bg-btn-primary); color: var(--color-text-white); padding: 20rpx 48rpx;
  border-radius: 40rpx; font-size: 28rpx;
}

.load-more, .no-more {
  text-align: center; padding: 30rpx; font-size: 24rpx; color: var(--color-text-muted);
}
