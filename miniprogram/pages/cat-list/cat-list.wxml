<!-- pages/cat-list/cat-list.wxml -->
<view class="page {{isDarkMode ? 'dark' : ''}}">
  <!-- 头部 -->
  <view class="header">
    <!-- 头部区域：承载标题、入口和当前状态信息。 -->
    <view class="header-top">
      <text class="page-title">🔍 发现</text>
      <view class="create-btn" bindtap="goCreateFormal">+ 建正式档案</view>
    </view>
    <!-- 搜索栏 -->
    <view class="search-bar">
      <input
        class="search-input"
        placeholder="搜索猫咪名字/代号/外貌..."
        value="{{keyword}}"
        bindinput="onKeywordInput"
        bindconfirm="doSearch"
      />
      <view class="search-btn" bindtap="doSearch">搜索</view>
      <view class="clear-btn" wx:if="{{searchMode}}" bindtap="clearSearch">✕</view>
    </view>
  </view>

  <!-- 标签栏（搜索模式下隐藏） -->
  <view class="tabs" wx:if="{{!searchMode}}">
    <view
      wx:for="{{tabs}}"
      wx:key="id"
      class="tab {{currentTab === item.id ? 'active' : ''}}"
      bindtap="onTabChange"
      data-tab="{{item.id}}"
    >{{item.name}}</view>
  </view>

  <!-- 搜索结果提示 -->
  <view class="search-tip" wx:if="{{searchMode}}">
    搜索"{{keyword}}"，找到 {{catList.length}} 只猫
  </view>

  <!-- 猫广场：基于发布帖子的 GPS 记录展示轨迹和活动范围估计 -->
  <view class="cat-square" wx:if="{{currentTab === 'square' && !searchMode}}">
    <!-- 猫广场区域：展示定位聚合和动态流内容。 -->
    <view class="square-intro">
      <view>
        <text class="square-title">📍 猫广场</text>
        <text class="square-desc">猫猫位置看轨迹，撸猫圈看大家的动态和评论入口。</text>
      </view>
      <view class="square-refresh" bindtap="loadCatSquare">刷新</view>
    </view>

    <!-- 猫广场区域：展示定位聚合和动态流内容。 -->
    <view class="square-switch">
      <view
        class="square-switch-item {{squareView === 'location' ? 'active' : ''}}"
        bindtap="onSquareViewChange"
        data-view="location"
      >猫猫位置</view>
      <view
        class="square-switch-item {{squareView === 'circle' ? 'active' : ''}}"
        bindtap="onSquareViewChange"
        data-view="circle"
      >撸猫圈</view>
    </view>

    <!-- 猫广场区域：展示定位聚合和动态流内容。 -->
    <view class="square-empty" wx:if="{{squareView === 'location' && !squareLoading && squareCats.length === 0}}">
      <text class="empty-icon">🐾</text>
      <text class="empty-text">还没有带 GPS 的猫咪动态</text>
      <text class="square-desc">发布帖子时点击“获取 GPS 定位”后，这里会自动汇总。</text>
    </view>

    <view wx:if="{{squareView === 'location' && selectedSquareCat}}">
      <map
        class="square-map"
        latitude="{{mapLatitude}}"
        longitude="{{mapLongitude}}"
        scale="18"
        markers="{{mapMarkers}}"
        polyline="{{mapPolyline}}"
        circles="{{mapCircles}}"
        show-location
      />

      <view class="prediction-card">
        <view class="prediction-main">
          <image
            wx:if="{{selectedSquareCat.coverImage}}"
            class="prediction-avatar"
            src="{{selectedSquareCat.coverImage}}"
            mode="aspectFill"
          />
          <view class="prediction-avatar prediction-avatar-empty" wx:else>🐱</view>
          <view class="prediction-info">
            <text class="prediction-name">{{selectedSquareCat.name}}</text>
            <text class="prediction-meta">{{selectedSquareCat.appearance}} · {{selectedSquareCat.points.length}} 条定位记录</text>
          </view>
        </view>
        <view class="prediction-range">
          <text>活动范围估计：约 {{selectedSquareCat.prediction.radius}} 米</text>
          <text>可信度：{{selectedSquareCat.prediction.confidenceText}}</text>
        </view>
      </view>

      <view class="square-cat-row">
        <scroll-view scroll-x class="square-cat-scroll">
          <view
            wx:for="{{squareCats}}"
            wx:key="catId"
            class="square-cat-chip {{selectedSquareCat.catId === item.catId ? 'active' : ''}}"
            bindtap="onSquareCatTap"
            data-catid="{{item.catId}}"
          >
            {{item.name}}
          </view>
        </scroll-view>
      </view>

      <view class="trace-list">
        <view class="trace-title">最近定位记录</view>
        <view wx:for="{{selectedSquareCat.points}}" wx:key="id" class="trace-item">
          <view class="trace-dot"></view>
          <view class="trace-body">
            <text class="trace-location">{{item.location}}</text>
            <text class="trace-time">{{item.timeText}}</text>
            <text class="trace-content" wx:if="{{item.content}}">{{item.content}}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 猫广场区域：展示定位聚合和动态流内容。 -->
    <view class="square-feed" wx:if="{{squareView === 'circle'}}">
      <view class="square-feed-empty" wx:if="{{!squareLoading && squareFeed.length === 0}}">
        <text class="empty-icon">💬</text>
        <text class="empty-text">还没有撸猫动态</text>
      </view>
      <view
        class="square-feed-card"
        wx:for="{{squareFeed}}"
        wx:key="_id"
        bindtap="onSquarePostTap"
        data-id="{{item._id}}"
      >
        <image
          class="square-feed-img"
          wx:if="{{item.images && item.images.length > 0}}"
          src="{{item.images[0]}}"
          mode="aspectFill"
        />
        <view class="square-feed-body">
          <text class="square-feed-content">{{item.content}}</text>
          <view class="square-feed-meta">
            <text>{{item.location || '地点未知'}}</text>
            <text>💬 {{item.commentCount || 0}}</text>
            <text>❤️ {{item.likeCount || 0}}</text>
          </view>
        </view>
      </view>
    </view>

    <view class="load-more" wx:if="{{squareLoading}}">加载猫广场...</view>
  </view>

  <!-- 人气榜特殊样式 -->
  <view class="rank-list" wx:if="{{currentTab === 'rank_total' && !searchMode}}">
    <view
      wx:for="{{catList}}"
      wx:key="_id"
      class="rank-item {{index < 3 ? 'top' + (index+1) : ''}}"
      bindtap="onCatTap"
      data-id="{{item._id}}"
    >
      <view class="rank-num">
        <text wx:if="{{index === 0}}">🥇</text>
        <text wx:elif="{{index === 1}}">🥈</text>
        <text wx:elif="{{index === 2}}">🥉</text>
        <text wx:else class="rank-num-text">{{index+1}}</text>
      </view>
      <image
        wx:if="{{item.coverImage}}"
        class="rank-avatar"
        src="{{item.coverImage}}"
        mode="aspectFill"
      />
      <view class="rank-avatar rank-avatar-empty" wx:else>🐱</view>
      <view class="rank-info">
        <text class="rank-name">{{item.fullName || item.codeName}}</text>
        <text class="rank-meta">{{item.appearance}} {{item.gender === 'male' ? '♂' : item.gender === 'female' ? '♀' : ''}}</text>
      </view>
      <view class="rank-vote">
        <text class="vote-num">{{item.totalVote || 0}}</text>
        <text class="vote-label">票</text>
      </view>
    </view>
    <view class="load-more" wx:if="{{loading}}">加载中...</view>
    <view class="no-more" wx:elif="{{!hasMore && catList.length > 0}}">已加载全部</view>
  </view>

  <!-- 普通列表 -->
  <view class="cat-grid" wx:if="{{(currentTab !== 'rank_total' && currentTab !== 'square') || searchMode}}">
    <view
      wx:for="{{catList}}"
      wx:key="_id"
      class="cat-card"
      bindtap="onCatTap"
      data-id="{{item._id}}"
    >
      <view class="cat-card-img-wrap">
        <image
          wx:if="{{item.coverImage}}"
          class="cat-card-img"
          src="{{item.coverImage}}"
          mode="aspectFill"
        />
        <view class="cat-card-img cat-img-empty" wx:else>🐱</view>
        <view class="cat-type-badge {{item.catType === 'formal' ? 'formal' : 'unknown'}}">
          {{item.catType === 'formal' ? '正式' : '未知'}}
        </view>
      </view>
      <view class="cat-card-body">
        <text class="cat-card-name">{{item.fullName || item.codeName}}</text>
        <text class="cat-card-meta">{{item.appearance}} · {{item.location || '地点未知'}}</text>
        <view class="cat-card-footer">
          <text class="vote-info">🏆 {{item.totalVote || 0}}票</text>
          <text class="cat-status status-{{item.status}}">{{item.status === 'active' ? '活跃' : item.status === 'lost' ? '走失' : '已领养'}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty" wx:if="{{!loading && currentTab !== 'square' && catList.length === 0}}">
    <text class="empty-icon">🐾</text>
    <text class="empty-text">还没有猫咪档案</text>
    <!-- 空状态区域：在暂无数据时给出提示信息。 -->
    <view class="empty-btn" bindtap="goCreateFormal">创建第一份正式档案</view>
  </view>

  <view class="load-more" wx:if="{{loading && catList.length > 0}}">加载中...</view>
  <view class="no-more" wx:elif="{{!hasMore && catList.length > 0 && !loading}}">已加载全部</view>
</view>
