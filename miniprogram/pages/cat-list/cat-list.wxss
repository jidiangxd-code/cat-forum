/* pages/cat-list/cat-list.wxss - 猫咪列表样式（已迁移到 CSS 变量）*/
.page { background: var(--color-bg); min-height: 100vh; }

.header {
  background: var(--banner-gradient);
  padding: 20rpx 24rpx 24rpx;
}
.header-top { display: flex; align-items: center; justify-content: space-between; margin-bottom: 16rpx; }
.page-title { font-size: 36rpx; font-weight: bold; color: var(--color-text-white); }
.create-btn {
  background: rgba(255,255,255,0.25); color: var(--color-text-white);
  padding: 10rpx 24rpx; border-radius: 30rpx; font-size: 24rpx;
}
.search-bar { display: flex; align-items: center; gap: 12rpx; }
.search-input {
  flex: 1; background: rgba(255,255,255,0.9); border-radius: 40rpx;
  padding: 14rpx 24rpx; font-size: 26rpx;
}
.search-btn {
  background: var(--color-bg-card); color: var(--color-text-accent); padding: 14rpx 24rpx;
  border-radius: 40rpx; font-size: 26rpx; font-weight: bold; flex-shrink: 0;
}
.clear-btn {
  background: rgba(255,255,255,0.3); color: var(--color-text-white);
  width: 60rpx; height: 60rpx; border-radius: 50%;
  display: flex; align-items: center; justify-content: center; font-size: 28rpx; flex-shrink: 0;
}
.search-tip {
  padding: 16rpx 28rpx; font-size: 24rpx; color: var(--color-text-secondary);
  background: var(--color-bg-card); border-bottom: 1rpx solid var(--color-border);
}
.tabs {
  display: flex; background: var(--color-bg-card); padding: 0 16rpx;
  border-bottom: 1rpx solid var(--color-border);
}
.tab {
  flex: 1; text-align: center; padding: 24rpx 0; font-size: 26rpx; color: var(--color-text-secondary);
}
.tab.active { color: var(--color-text-accent); border-bottom: 4rpx solid var(--color-text-accent); font-weight: bold; }
.rank-list { padding: 16rpx 24rpx; }
.rank-item {
  display: flex; align-items: center; background: var(--color-bg-card);
  border-radius: 16rpx; padding: 20rpx; margin-bottom: 16rpx;
  box-shadow: var(--color-shadow-card);
}
/* 排名颜色保持固定（金/银/铜） */
.rank-item.top1 { border-left: 6rpx solid #FFD700; background: var(--color-bg-card); }
.rank-item.top2 { border-left: 6rpx solid #C0C0C0; background: var(--color-bg-card); }
.rank-item.top3 { border-left: 6rpx solid #CD7F32; background: var(--color-bg-card); }
.rank-num { width: 60rpx; text-align: center; font-size: 36rpx; flex-shrink: 0; }
.rank-num-text { font-size: 28rpx; color: var(--color-text-secondary); font-weight: bold; }
.rank-avatar {
  width: 88rpx; height: 88rpx; border-radius: 50%; margin: 0 20rpx;
  overflow: hidden; flex-shrink: 0;
}
.rank-avatar-empty {
  background: var(--color-bg-tag); display: flex; align-items: center;
  justify-content: center; font-size: 44rpx; border-radius: 50%;
}
.rank-info { flex: 1; }
.rank-name { display: block; font-size: 30rpx; font-weight: bold; color: var(--color-text-primary); }
.rank-meta { display: block; font-size: 22rpx; color: var(--color-text-secondary); margin-top: 4rpx; }
.rank-vote { text-align: center; flex-shrink: 0; }
.vote-num { display: block; font-size: 36rpx; font-weight: bold; color: var(--color-text-accent); }
.vote-label { display: block; font-size: 20rpx; color: var(--color-text-desc); }
.cat-grid {
  display: grid; grid-template-columns: 1fr 1fr;
  gap: 20rpx; padding: 20rpx 24rpx;
}
.cat-card {
  background: var(--color-bg-card); border-radius: 20rpx;
  overflow: hidden; box-shadow: var(--color-shadow-card);
}
.cat-card-img-wrap { position: relative; }
.cat-card-img { width: 100%; height: 220rpx; display: block; }
.cat-img-empty {
  height: 220rpx; background: var(--color-bg-tag);
  display: flex; align-items: center; justify-content: center; font-size: 72rpx;
}
.cat-type-badge {
  position: absolute; top: 12rpx; right: 12rpx;
  padding: 6rpx 14rpx; border-radius: 20rpx;
  font-size: 20rpx; font-weight: bold;
}
.cat-type-badge.formal { background: var(--color-bg-badge); color: var(--color-text-white); }
.cat-type-badge.unknown { background: var(--color-text-blue); color: var(--color-text-white); }
.cat-card-body { padding: 16rpx; }
.cat-card-name { display: block; font-size: 28rpx; font-weight: bold; color: var(--color-text-primary); margin-bottom: 6rpx; }
.cat-card-meta { display: block; font-size: 22rpx; color: var(--color-text-secondary); margin-bottom: 10rpx; }
.cat-card-footer { display: flex; align-items: center; justify-content: space-between; }
.vote-info { font-size: 22rpx; color: var(--color-text-accent); }
.cat-status { font-size: 20rpx; padding: 4rpx 10rpx; border-radius: 10rpx; }
.status-active { background: var(--color-bg-tag-health); color: var(--color-text-tag-health); }
.status-lost { background: var(--color-bg-tag); color: var(--color-text-accent); }
.status-adopted { background: var(--color-bg-tag); color: var(--color-text-blue); }
.empty {
  display: flex; flex-direction: column; align-items: center;
  padding: 120rpx 40rpx;
}
.empty-icon { font-size: 80rpx; margin-bottom: 20rpx; }
.empty-text { font-size: 28rpx; color: var(--color-text-secondary); margin-bottom: 32rpx; }
.empty-btn {
  background: var(--color-bg-btn-primary); color: var(--color-text-white); padding: 20rpx 48rpx;
  border-radius: 40rpx; font-size: 28rpx;
}
.load-more, .no-more {
  text-align: center; padding: 30rpx; font-size: 24rpx; color: var(--color-text-muted);
}
