/* pages/create-cat/create-cat.wxss */
.page {
  background: #fff5eb;
  min-height: 100vh;
  padding-bottom: 120rpx;
}

/* 封面图与占位背景样式。 */
.cover-section {
  width: 100%;
  height: 300rpx;
  overflow: hidden;
  background: #f0f0f0;
  position: relative;
}
.cover-img {
  width: 100%;
  height: 100%;
}
.cover-placeholder {
  height: 300rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #ffe0c0, #ffbf9a);
}
.cover-icon {
  font-size: 60rpx;
}
.cover-tip {
  font-size: 24rpx;
  color: #fff;
  margin-top: 12rpx;
}

/* 表单输入与字段布局样式。 */
.form {
  padding: 0 24rpx;
}
.form-group {
  background: #fff;
  border-radius: 16rpx;
  margin-top: 20rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.03);
}
.form-label {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
  display: block;
}
.required {
  color: #f44;
}
.optional {
  color: #bbb;
  font-weight: normal;
  font-size: 24rpx;
}
/* 表单输入与字段布局样式。 */
.form-input {
  width: 100%;
  background: #f8f8f8;
  border-radius: 10rpx;
  padding: 18rpx 20rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
  border: 1rpx solid #eee;
}

.tag-wrap {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}
.tag {
  padding: 12rpx 28rpx;
  border-radius: 30rpx;
  border: 2rpx solid #eee;
  font-size: 26rpx;
  color: #666;
  background: #fff;
}
.tag.selected {
  background: #ff9a6a;
  border-color: #ff9a6a;
  color: #fff;
}

.btn-group {
  display: flex;
  gap: 16rpx;
}
.option-btn {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  border-radius: 12rpx;
  border: 2rpx solid #eee;
  font-size: 26rpx;
  color: #666;
  background: #fff;
}
.option-btn.selected {
  background: #ff9a6a;
  border-color: #ff9a6a;
  color: #fff;
  font-weight: bold;
}

/* 提交按钮与底部提交区样式。 */
.submit-wrap {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 32rpx 40rpx;
  background: #fff;
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.06);
}
.submit-btn {
  width: 100%;
  height: 88rpx;
  border-radius: 44rpx;
  background: linear-gradient(135deg, #ff9a6a, #ff7043);
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}
.submit-btn.disabled {
  background: #ccc;
}
