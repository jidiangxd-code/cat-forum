/* pages/create-cat/create-cat.wxss - 创建猫咪页样式（已迁移到 CSS 变量）*/
.page { background: var(--color-bg); min-height: 100vh; padding-bottom: 120rpx; }

.cover-section {
  width: 100%; height: 300rpx; overflow: hidden;
  background: var(--color-bg-image); position: relative;
}
.cover-img { width: 100%; height: 100%; }
.cover-placeholder {
  height: 300rpx; display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  background: var(--banner-gradient);
}
.cover-icon { font-size: 60rpx; }
.cover-tip { font-size: 24rpx; color: var(--color-text-white); margin-top: 12rpx; }

.form { padding: 0 24rpx; }
.form-group {
  background: var(--color-bg-card); border-radius: 16rpx; margin-top: 20rpx;
  padding: 24rpx;
  box-shadow: var(--color-shadow-card);
}
.form-label {
  font-size: 28rpx; font-weight: bold; color: var(--color-text-primary); margin-bottom: 16rpx;
  display: block;
}
.required { color: var(--color-error); }
.optional { color: var(--color-text-muted); font-weight: normal; font-size: 24rpx; }
.form-input {
  width: 100%; background: var(--color-bg-disabled); border-radius: 10rpx;
  padding: 18rpx 20rpx; font-size: 28rpx; color: var(--color-text-primary);
  box-sizing: border-box; border: 1rpx solid var(--color-border);
}

.tag-wrap { display: flex; flex-wrap: wrap; gap: 14rpx; }
.tag {
  padding: 12rpx 28rpx; border-radius: 30rpx;
  border: 2rpx solid var(--color-border); font-size: 26rpx; color: var(--color-text-secondary);
  background: var(--color-bg-card);
}
.tag.selected {
  background: var(--color-bg-btn-primary); border-color: var(--color-bg-btn-primary); color: var(--color-text-white);
}

.btn-group { display: flex; gap: 16rpx; }
.option-btn {
  flex: 1; text-align: center; padding: 16rpx 0; border-radius: 12rpx;
  border: 2rpx solid var(--color-border); font-size: 26rpx; color: var(--color-text-secondary);
  background: var(--color-bg-card);
}
.option-btn.selected {
  background: var(--color-bg-btn-primary); border-color: var(--color-bg-btn-primary); color: var(--color-text-white); font-weight: bold;
}

.submit-wrap {
  position: fixed; bottom: 0; left: 0; right: 0;
  padding: 20rpx 32rpx 40rpx;
  background: var(--color-bg-card);
  box-shadow: var(--color-shadow-modal);
}
.submit-btn {
  width: 100%; height: 88rpx; border-radius: 44rpx;
  background: var(--btn-primary-gradient);
  color: var(--color-text-white); font-size: 32rpx; font-weight: bold;
  border: none; display: flex; align-items: center; justify-content: center;
}
.submit-btn.disabled { background: var(--color-bg-disabled); color: var(--color-text-muted); }
