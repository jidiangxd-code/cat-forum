/* pages/search/search.wxss - 搜索页样式（已迁移到 CSS 变量）*/
.page {
  min-height: 100vh;
  background-color: var(--color-bg);
}

/* 搜索框区域 */
.search-bar {
  position: sticky;
  top: 0;
  z-index: 100;
  background: var(--banner-gradient);
  padding: 16rpx 24rpx 24rpx;
}

.search-input-wrap {
  display: flex;
  align-items: center;
  background-color: var(--color-bg-card);
  border-radius: 40rpx;
  padding: 0 24rpx;
  height: 72rpx;
}

.search-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: var(--color-text-primary);
  height: 72rpx;
  line-height: 72rpx;
}

.search-clear {
  font-size: 32rpx;
  color: var(--color-text-muted);
  padding: 8rpx;
}

/* Tab 切换 */
.search-tabs {
  display: flex;
  background-color: var(--color-bg-card);
  border-bottom: 1rpx solid var(--color-border);
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  font-size: 28rpx;
  color: var(--color-text-secondary);
  position: relative;
}

.tab-item.active {
  color: var(--color-text-accent);
  font-weight: bold;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 48rpx;
  height: 4rpx;
  background: var(--color-text-accent);
  border-radius: 4rpx;
}

/* 搜索历史 */
.history-section {
  padding: 20rpx 24rpx;
}

.history-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.history-title {
  font-size: 26rpx;
  color: var(--color-text-secondary);
}

.history-clear {
  font-size: 24rpx;
  color: var(--color-text-accent);
}

.history-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.history-tag {
  background-color: var(--color-bg-card);
  color: var(--color-text-secondary);
  padding: 10rpx 24rpx;
  border-radius: 24rpx;
  font-size: 26rpx;
  border: 1rpx solid var(--color-border);
}

.history-tag:active {
  background-color: var(--color-bg-hover);
  color: var(--color-text-accent);
}

/* 搜索结果 */
.result-list {
  padding: 16rpx 0;
}

/* ===== 猫咪卡片 ===== */
.cat-card {
  display: flex;
  align-items: center;
  background: var(--color-bg-card);
  padding: 20rpx 24rpx;
  margin: 0 16rpx 12rpx;
  border-radius: 16rpx;
  box-shadow: var(--color-shadow-card);
}

.cat-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  margin-right: 16rpx;
  overflow: hidden;
  flex-shrink: 0;
  background: var(--avatar-bg);
}

.cat-avatar image {
  width: 100%;
  height: 100%;
}

.cat-info {
  flex: 1;
  min-width: 0;
}

.cat-name {
  font-size: 30rpx;
  font-weight: bold;
  color: var(--color-text-primary);
  margin-bottom: 6rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.cat-meta {
  font-size: 22rpx;
  color: var(--color-text-desc);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.cat-vote {
  font-size: 24rpx;
  color: var(--color-text-accent);
  font-weight: bold;
  flex-shrink: 0;
  margin-left: 12rpx;
}

/* ===== 帖子卡片 ===== */
.post-card {
  background: var(--color-bg-card);
  margin: 0 16rpx 12rpx;
  padding: 20rpx 24rpx;
  border-radius: 16rpx;
  box-shadow: var(--color-shadow-card);
}

.post-header {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.post-cat-name {
  font-size: 24rpx;
  color: var(--color-text-accent);
  margin-left: 8rpx;
}

.post-text {
  font-size: 28rpx;
  color: var(--color-text-primary);
  line-height: 1.6;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 3;
  overflow: hidden;
}

.post-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 10rpx;
}

.post-time {
  font-size: 22rpx;
  color: var(--color-text-desc);
}

.post-stats {
  font-size: 22rpx;
  color: var(--color-text-desc);
}

/* 空状态 */
.empty-result {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 40rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: var(--color-text-secondary);
  text-align: center;
}

/* 热门搜索 */
.hot-section {
  padding: 20rpx 24rpx;
}

.hot-title {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  margin-bottom: 16rpx;
}

.hot-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.hot-tag {
  background-color: var(--color-bg-card);
  color: var(--color-text-secondary);
  padding: 10rpx 24rpx;
  border-radius: 24rpx;
  font-size: 26rpx;
  border: 1rpx solid var(--color-border);
}

.hot-tag:active {
  background-color: var(--color-bg-hover);
  color: var(--color-text-accent);
}

/* 加载提示 */
.loading-tip {
  text-align: center;
  padding: 40rpx;
  font-size: 26rpx;
  color: var(--color-text-desc);
}
