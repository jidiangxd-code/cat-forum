.page-container {
  min-height: 100vh;
  background: #fff5eb;
  padding-bottom: 40rpx;
}

/* 加载状态 */
.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
}

.loading-icon {
  font-size: 80rpx;
  animation: bounce 1s infinite;
}

.loading-text {
  margin-top: 20rpx;
  color: #999;
  font-size: 28rpx;
}

@keyframes bounce {
  0%,
  100% {
    transform: translateY(0);
  }
  50% {
    transform: translateY(-20rpx);
  }
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 60rpx;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
}

.empty-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}

.empty-desc {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 50rpx;
}

.empty-btn {
  background: linear-gradient(135deg, #ff9500, #ffb74d);
  color: #fff;
  padding: 20rpx 60rpx;
  border-radius: 50rpx;
  font-size: 30rpx;
}

/* 评论列表 */
.comments-list {
  padding: 0 30rpx;
}

.comment-card {
  background: #fff;
  border-radius: 24rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

/* 猫咪信息区域 */
.cat-info {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: #fff8f0;
  border-bottom: 1rpx solid #f0e6d8;
}

.cat-cover {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-right: 20rpx;
  border: 2rpx solid #ffe0cc;
}

.cat-text {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.cat-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 6rpx;
}

.cat-hint {
  font-size: 22rpx;
  color: #999;
}

.cat-arrow {
  font-size: 40rpx;
  color: #ccc;
}

/* 评论内容区域 */
.comment-content {
  padding: 24rpx;
}

.comment-text {
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
  display: block;
  margin-bottom: 20rpx;
}

.comment-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.comment-time {
  font-size: 24rpx;
  color: #999;
}

.comment-delete {
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  background: #fff0f0;
}

.delete-text {
  font-size: 24rpx;
  color: #ff4d4f;
}
