/* pages/my-posts/my-posts.wxss（已迁移到 CSS 变量）*/
.page-container {
  min-height: 100vh;
  background: var(--color-bg);
  padding-bottom: 40rpx;
}

/* 加载状态 */
.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
}

.loading-icon {
  font-size: 80rpx;
  animation: bounce 1s infinite;
}

.loading-text {
  margin-top: 20rpx;
  color: var(--color-text-secondary);
  font-size: 28rpx;
}

@keyframes bounce {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-20rpx); }
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 60rpx;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
}

.empty-title {
  font-size: 36rpx;
  font-weight: bold;
  color: var(--color-text-primary);
  margin-bottom: 16rpx;
}

.empty-desc {
  font-size: 28rpx;
  color: var(--color-text-secondary);
  margin-bottom: 50rpx;
}

.empty-btn {
  background: var(--btn-primary-gradient);
  color: var(--color-text-white);
  padding: 20rpx 60rpx;
  border-radius: 50rpx;
  font-size: 30rpx;
}

/* 帖子列表 */
.posts-list {
  padding: 0 30rpx;
}

.post-item {
  background: var(--color-bg-card);
  border-radius: 24rpx;
  margin-bottom: 24rpx;
  padding: 24rpx;
  box-shadow: var(--color-shadow-card);
  position: relative;
}

.post-cover {
  width: 100%;
  height: 300rpx;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
}

.post-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.post-title {
  font-size: 32rpx;
  font-weight: bold;
  color: var(--color-text-primary);
}

.post-tag {
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
}

.post-tag.stray {
  background: var(--color-bg-tag);
  color: var(--color-text-accent);
}

.post-tag.pet {
  background: var(--color-bg-tag-health);
  color: var(--color-text-tag-health);
}

.post-tag.lost {
  background: var(--color-bg-tag-red);
  color: var(--color-text-red);
}

.post-desc {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  line-height: 1.6;
  margin-bottom: 16rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.post-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.post-location {
  font-size: 24rpx;
  color: var(--color-text-desc);
}

.post-stats {
  display: flex;
  gap: 24rpx;
}

.stat-item {
  font-size: 24rpx;
  color: var(--color-text-desc);
}

.delete-hint {
  position: absolute;
  top: 24rpx;
  right: 24rpx;
}

.delete-text {
  font-size: 20rpx;
  color: var(--color-text-muted);
  background: var(--color-bg-disabled);
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}
