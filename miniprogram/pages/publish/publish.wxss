/* pages/publish/publish.wxss */
.page {
  background: #FFF5EB;
  min-height: 100vh;
  padding-bottom: 120rpx;
}
.header {
  background: linear-gradient(135deg, #FF9A6A, #FF7043);
  padding: 40rpx 32rpx 32rpx;
  color: #fff;
}
.title { font-size: 40rpx; font-weight: bold; display: block; }
.subtitle { font-size: 24rpx; opacity: 0.85; margin-top: 8rpx; display: block; }

.section {
  background: #fff;
  margin: 20rpx 24rpx 0;
  border-radius: 20rpx;
  padding: 28rpx 28rpx 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}
.section-label {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 18rpx;
}
.required { color: #f44; }
.tip { color: #999; font-weight: normal; font-size: 24rpx; }

/* 图片网格 */
.image-grid { display: flex; flex-wrap: wrap; gap: 16rpx; }
.img-item { position: relative; width: 200rpx; height: 200rpx; border-radius: 12rpx; overflow: hidden; }
.preview-img { width: 100%; height: 100%; }
.del-btn {
  position: absolute; top: 6rpx; right: 6rpx;
  width: 40rpx; height: 40rpx; border-radius: 50%;
  background: rgba(0,0,0,0.55); color: #fff;
  font-size: 22rpx; display: flex; align-items: center; justify-content: center;
}
.img-add {
  width: 200rpx; height: 200rpx; border-radius: 12rpx;
  border: 2rpx dashed #FFBF9A;
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  background: #FFF9F5;
}
.add-icon { font-size: 48rpx; color: #FF9A6A; line-height: 1; }
.add-text { font-size: 22rpx; color: #FF9A6A; margin-top: 8rpx; }

/* 描述输入 */
.desc-input {
  width: 100%; min-height: 160rpx; font-size: 28rpx; color: #333;
  line-height: 1.6; background: #F9F9F9; border-radius: 12rpx;
  padding: 20rpx; box-sizing: border-box;
}
.char-count { display: block; text-align: right; font-size: 22rpx; color: #bbb; margin-top: 8rpx; }

/* 分类选择 */
.category-grid { display: flex; flex-wrap: wrap; gap: 12rpx; }
.category-tag {
  padding: 12rpx 28rpx; border-radius: 30rpx;
  border: 2rpx solid #eee; font-size: 26rpx; color: #555;
  background: #f9f9f9;
}
.category-tag.selected {
  background: #FF9A6A; border-color: #FF9A6A; color: #fff;
}

/* 绑猫区 */
.bind-section {}
.bind-options { display: flex; flex-direction: column; gap: 16rpx; }
.bind-btn {
  display: flex; align-items: center; padding: 24rpx 20rpx;
  border-radius: 16rpx; border: 2rpx solid #eee;
}
.bind-btn-a { background: #FFF5EB; border-color: #FFD4A8; }
.bind-btn-b { background: #F0F9FF; border-color: #A8D9FF; }
.bind-btn-c { background: #F5FFF0; border-color: #A8DFAA; }
.bind-icon { font-size: 40rpx; margin-right: 20rpx; }
.bind-text-wrap { flex: 1; }
.bind-title { display: block; font-size: 28rpx; font-weight: bold; color: #333; }
.bind-desc { display: block; font-size: 22rpx; color: #999; margin-top: 4rpx; }
.bind-arrow { font-size: 36rpx; color: #ccc; }

/* 已选猫咪 */
.selected-cat {}
.cat-preview-card {
  display: flex; align-items: center; padding: 20rpx;
  background: #FFF5EB; border-radius: 16rpx; border: 2rpx solid #FFD4A8;
}
.cat-avatar {
  width: 88rpx; height: 88rpx; border-radius: 50%; overflow: hidden;
  margin-right: 20rpx; flex-shrink: 0;
}
.cat-avatar-placeholder {
  background: #FFE0C0; display: flex; align-items: center;
  justify-content: center; font-size: 44rpx;
}
.cat-info .cat-name { display: block; font-size: 30rpx; font-weight: bold; color: #333; }
.cat-info .cat-meta { display: block; font-size: 22rpx; color: #999; margin-top: 4rpx; }
.re-select {
  text-align: center; margin-top: 16rpx; font-size: 24rpx;
  color: #FF9A6A; text-decoration: underline;
}

/* 新建未知猫表单 */
.new-unknown-form {
  border: 2rpx solid #A8DFAA; border-radius: 16rpx;
  background: #F5FFF0; padding: 24rpx;
}
.form-row { margin-bottom: 20rpx; }
.form-label { display: block; font-size: 26rpx; color: #555; margin-bottom: 10rpx; }
.form-input {
  width: 100%; background: #fff; border: 1rpx solid #ddd;
  border-radius: 10rpx; padding: 16rpx; font-size: 28rpx;
  box-sizing: border-box;
}
.appearance-grid { display: flex; flex-wrap: wrap; gap: 12rpx; }
.appearance-tag {
  padding: 10rpx 24rpx; border-radius: 30rpx;
  border: 2rpx solid #ddd; font-size: 26rpx; color: #555;
  background: #fff;
}
.appearance-tag.selected {
  background: #FF9A6A; border-color: #FF9A6A; color: #fff;
}
.cancel-new {
  text-align: center; margin-top: 16rpx; font-size: 24rpx;
  color: #999; text-decoration: underline;
}

/* 提交 */
.submit-wrap {
  position: fixed; bottom: 0; left: 0; right: 0;
  padding: 20rpx 32rpx 40rpx;
  background: #fff;
  box-shadow: 0 -2rpx 12rpx rgba(0,0,0,0.06);
}
.preview-btn {
  width: 100%; height: 88rpx; border-radius: 44rpx;
  background: linear-gradient(135deg, #FF9A6A, #FF7043);
  color: #fff; font-size: 32rpx; font-weight: bold;
  border: none; display: flex; align-items: center; justify-content: center;
}
.submit-btn {
  width: 100%; height: 88rpx; border-radius: 44rpx;
  background: linear-gradient(135deg, #FF9A6A, #FF7043);
  color: #fff; font-size: 32rpx; font-weight: bold;
  border: none; display: flex; align-items: center; justify-content: center;
  margin-top: 16rpx;
}
.submit-btn.disabled { background: #ccc; }

/* ========== 预览模式样式 ========== */
.preview-page {
  min-height: 100vh;
  background: #FFF5EB;
  display: flex;
  flex-direction: column;
}

.preview-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  background: #fff;
  border-bottom: 1rpx solid #f0f0f0;
}

.preview-back {
  font-size: 28rpx;
  color: #FF9A6A;
}

.preview-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.preview-placeholder {
  width: 120rpx;
}

.preview-scroll {
  flex: 1;
  overflow: hidden;
}

.preview-content {
  padding-bottom: 160rpx;
}

.preview-swiper {
  width: 100%;
  height: 600rpx;
}

.swiper-img {
  width: 100%;
  height: 100%;
}

.preview-cat-card {
  display: flex;
  align-items: center;
  padding: 24rpx 32rpx;
  background: #fff;
  margin: 20rpx 24rpx;
  border-radius: 16rpx;
}

.preview-cat-avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  overflow: hidden;
  background: #FFE0C0;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.cat-avatar-img {
  width: 100%;
  height: 100%;
}

.cat-avatar-text {
  font-size: 44rpx;
}

.preview-cat-info {
  flex: 1;
}

.preview-cat-name {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.preview-cat-meta {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-top: 6rpx;
}

.preview-category {
  padding: 0 32rpx;
  margin-bottom: 16rpx;
}

.category-badge {
  display: inline-block;
  padding: 8rpx 24rpx;
  background: #FFE8DB;
  color: #FF7043;
  font-size: 24rpx;
  border-radius: 20rpx;
}

.preview-text {
  padding: 24rpx 32rpx;
  background: #fff;
  margin: 0 24rpx;
  border-radius: 16rpx;
  font-size: 30rpx;
  line-height: 1.8;
  color: #333;
}

.preview-tip {
  padding: 32rpx;
  text-align: center;
}

.preview-tip text {
  font-size: 24rpx;
  color: #999;
}

.preview-footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 32rpx 40rpx;
  background: #fff;
  box-shadow: 0 -2rpx 12rpx rgba(0,0,0,0.06);
  display: flex;
  gap: 20rpx;
}

.edit-again-btn {
  flex: 1;
  height: 88rpx;
  border-radius: 44rpx;
  background: #f5f5f5;
  color: #666;
  font-size: 28rpx;
  border: none;
}

.confirm-publish-btn {
  flex: 2;
  height: 88rpx;
  border-radius: 44rpx;
  background: linear-gradient(135deg, #FF9A6A, #FF7043);
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
  border: none;
}

.confirm-publish-btn.disabled {
  background: #ccc;
}

/* 弹窗 */
.picker-mask {
  position: fixed; inset: 0; background: rgba(0,0,0,0.4); z-index: 100;
}
.cat-picker {
  position: fixed; bottom: 0; left: 0; right: 0;
  background: #fff; border-radius: 32rpx 32rpx 0 0;
  z-index: 101; max-height: 80vh;
  display: flex; flex-direction: column;
}
.picker-header {
  display: flex; align-items: center; justify-content: space-between;
  padding: 28rpx 32rpx 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}
.picker-title { font-size: 32rpx; font-weight: bold; color: #333; }
.picker-close { font-size: 36rpx; color: #999; padding: 0 8rpx; }
.picker-search { padding: 16rpx 24rpx; }
.search-input {
  width: 100%; background: #F5F5F5; border-radius: 40rpx;
  padding: 16rpx 24rpx; font-size: 26rpx; box-sizing: border-box;
}
.picker-list { flex: 1; overflow: hidden; }
.loading-tip, .empty-tip {
  text-align: center; padding: 60rpx; color: #999; font-size: 26rpx;
}
.picker-item {
  display: flex; align-items: center; padding: 20rpx 28rpx;
  border-bottom: 1rpx solid #f8f8f8;
}
.picker-avatar {
  width: 80rpx; height: 80rpx; border-radius: 50%; margin-right: 20rpx; flex-shrink: 0;
  overflow: hidden;
}
.picker-avatar-empty {
  background: #FFE0C0; display: flex; align-items: center;
  justify-content: center; font-size: 36rpx; border-radius: 50%;
}
.picker-cat-info { flex: 1; }
.picker-cat-name { display: block; font-size: 28rpx; font-weight: bold; color: #333; }
.picker-cat-meta { display: block; font-size: 22rpx; color: #999; margin-top: 4rpx; }
.picker-cat-vote { font-size: 24rpx; color: #FF9A6A; flex-shrink: 0; }
