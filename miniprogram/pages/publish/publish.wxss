/* pages/publish/publish.wxss - 发帖页样式（已迁移到 CSS 变量）*/
.page {
  background: var(--color-bg);
  min-height: 100vh;
  padding-bottom: 120rpx;
}
.header {
  background: var(--banner-gradient);
  padding: 40rpx 32rpx 32rpx;
  color: var(--color-text-white);
}
.title { font-size: 40rpx; font-weight: bold; display: block; }
.subtitle { font-size: 24rpx; opacity: 0.85; margin-top: 8rpx; display: block; }

.section {
  background: var(--color-bg-card);
  margin: 20rpx 24rpx 0;
  border-radius: 20rpx;
  padding: 28rpx 28rpx 20rpx;
  box-shadow: var(--color-shadow-card);
}
.section-label {
  font-size: 28rpx;
  font-weight: bold;
  color: var(--color-text-primary);
  margin-bottom: 18rpx;
}
.required { color: var(--color-error); }
.tip { color: var(--color-text-secondary); font-weight: normal; font-size: 24rpx; }

/* 图片网格 */
.image-grid { display: flex; flex-wrap: wrap; gap: 16rpx; }
.img-item { position: relative; width: 200rpx; height: 200rpx; border-radius: 12rpx; overflow: hidden; }
.preview-img { width: 100%; height: 100%; }
.del-btn {
  position: absolute; top: 6rpx; right: 6rpx;
  width: 40rpx; height: 40rpx; border-radius: 50%;
  background: rgba(0,0,0,0.55); color: var(--color-text-white);
  font-size: 22rpx; display: flex; align-items: center; justify-content: center;
}
.img-add {
  width: 200rpx; height: 200rpx; border-radius: 12rpx;
  border: 2rpx dashed var(--color-border);
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  background: var(--color-bg-tag);
}
.add-icon { font-size: 48rpx; color: var(--color-text-accent); line-height: 1; }
.add-text { font-size: 22rpx; color: var(--color-text-accent); margin-top: 8rpx; }

/* 描述输入 */
.desc-input {
  width: 100%; min-height: 160rpx; font-size: 28rpx; color: var(--color-text-primary);
  line-height: 1.6; background: var(--color-bg-disabled); border-radius: 12rpx;
  padding: 20rpx; box-sizing: border-box;
}
.char-count { display: block; text-align: right; font-size: 22rpx; color: var(--color-text-muted); margin-top: 8rpx; }

/* 分类选择 */
.category-grid { display: flex; flex-wrap: wrap; gap: 12rpx; }
.category-tag {
  padding: 12rpx 28rpx; border-radius: 30rpx;
  border: 2rpx solid var(--color-border); font-size: 26rpx; color: var(--color-text-secondary);
  background: var(--color-bg-disabled);
}
.category-tag.selected {
  background: var(--color-bg-btn-primary); border-color: var(--color-bg-btn-primary); color: var(--color-text-white);
}

/* 绑猫区 */
.bind-section {}
.bind-options { display: flex; flex-direction: column; gap: 16rpx; }
.bind-btn {
  display: flex; align-items: center; padding: 24rpx 20rpx;
  border-radius: 16rpx; border: 2rpx solid var(--color-border);
}
/* 特殊颜色 - 绑猫选项 */
.bind-btn-a { background: var(--color-bg); border-color: var(--color-border); }
.bind-btn-b { background: var(--color-bg-tag-blue); border-color: var(--color-border-blue); }
.bind-btn-c { background: var(--color-bg-tag-green); border-color: var(--color-border-green); }
.bind-icon { font-size: 40rpx; margin-right: 20rpx; }
.bind-text-wrap { flex: 1; }
.bind-title { display: block; font-size: 28rpx; font-weight: bold; color: var(--color-text-primary); }
.bind-desc { display: block; font-size: 22rpx; color: var(--color-text-secondary); margin-top: 4rpx; }
.bind-arrow { font-size: 36rpx; color: var(--color-text-muted); }

/* 已选猫咪 */
.selected-cat {}
.cat-preview-card {
  display: flex; align-items: center; padding: 20rpx;
  background: var(--color-bg); border-radius: 16rpx; border: 2rpx solid var(--color-border);
}
.cat-avatar {
  width: 88rpx; height: 88rpx; border-radius: 50%; overflow: hidden;
  margin-right: 20rpx; flex-shrink: 0;
}
.cat-avatar-placeholder {
  background: var(--color-bg-tag); display: flex; align-items: center;
  justify-content: center; font-size: 44rpx;
}
.cat-info .cat-name { display: block; font-size: 30rpx; font-weight: bold; color: var(--color-text-primary); }
.cat-info .cat-meta { display: block; font-size: 22rpx; color: var(--color-text-secondary); margin-top: 4rpx; }
.re-select {
  text-align: center; margin-top: 16rpx; font-size: 24rpx;
  color: var(--color-text-accent); text-decoration: underline;
}

/* 新建未知猫表单 */
.new-unknown-form {
  border: 2rpx solid var(--color-border-green); border-radius: 16rpx;
  background: var(--color-bg-tag-green); padding: 24rpx;
}
.form-row { margin-bottom: 20rpx; }
.form-label { display: block; font-size: 26rpx; color: var(--color-text-secondary); margin-bottom: 10rpx; }
.form-input {
  width: 100%; background: var(--color-bg-card); border: 1rpx solid var(--color-border);
  border-radius: 10rpx; padding: 16rpx; font-size: 28rpx;
  box-sizing: border-box;
}
.appearance-grid { display: flex; flex-wrap: wrap; gap: 12rpx; }
.appearance-tag {
  padding: 10rpx 24rpx; border-radius: 30rpx;
  border: 2rpx solid var(--color-border); font-size: 26rpx; color: var(--color-text-secondary);
  background: var(--color-bg-card);
}
.appearance-tag.selected {
  background: var(--color-bg-btn-primary); border-color: var(--color-bg-btn-primary); color: var(--color-text-white);
}
.cancel-new {
  text-align: center; margin-top: 16rpx; font-size: 24rpx;
  color: var(--color-text-secondary); text-decoration: underline;
}

/* 提交 */
.submit-wrap {
  position: fixed; bottom: 0; left: 0; right: 0;
  padding: 20rpx 32rpx 40rpx;
  background: var(--color-bg-card);
  box-shadow: var(--color-shadow-modal);
}
.submit-btn {
  width: 100%; height: 88rpx; border-radius: 44rpx;
  background: var(--btn-primary-gradient);
  color: var(--color-text-white); font-size: 32rpx; font-weight: bold;
  border: none; display: flex; align-items: center; justify-content: center;
}
.submit-btn.disabled { background: var(--color-bg-disabled); color: var(--color-text-muted); }

/* 弹窗 */
.picker-mask {
  position: fixed; inset: 0; background: rgba(0,0,0,0.4); z-index: 100;
}
.cat-picker {
  position: fixed; bottom: 0; left: 0; right: 0;
  background: var(--color-bg-card); border-radius: 32rpx 32rpx 0 0;
  z-index: 101; max-height: 80vh;
  display: flex; flex-direction: column;
}
.picker-header {
  display: flex; align-items: center; justify-content: space-between;
  padding: 28rpx 32rpx 20rpx;
  border-bottom: 1rpx solid var(--color-border);
}
.picker-title { font-size: 32rpx; font-weight: bold; color: var(--color-text-primary); }
.picker-close { font-size: 36rpx; color: var(--color-text-secondary); padding: 0 8rpx; }
.picker-search { padding: 16rpx 24rpx; }
.search-input {
  width: 100%; background: var(--color-bg-disabled); border-radius: 40rpx;
  padding: 16rpx 24rpx; font-size: 26rpx; box-sizing: border-box;
}
.picker-list { flex: 1; overflow: hidden; }
.loading-tip, .empty-tip {
  text-align: center; padding: 60rpx; color: var(--color-text-secondary); font-size: 26rpx;
}
.picker-item {
  display: flex; align-items: center; padding: 20rpx 28rpx;
  border-bottom: 1rpx solid var(--color-border);
}
.picker-avatar {
  width: 80rpx; height: 80rpx; border-radius: 50%; margin-right: 20rpx; flex-shrink: 0;
  overflow: hidden;
}
.picker-avatar-empty {
  background: var(--color-bg-tag); display: flex; align-items: center;
  justify-content: center; font-size: 36rpx; border-radius: 50%;
}
.picker-cat-info { flex: 1; }
.picker-cat-name { display: block; font-size: 28rpx; font-weight: bold; color: var(--color-text-primary); }
.picker-cat-meta { display: block; font-size: 22rpx; color: var(--color-text-secondary); margin-top: 4rpx; }
.picker-cat-vote { font-size: 24rpx; color: var(--color-text-accent); flex-shrink: 0; }
