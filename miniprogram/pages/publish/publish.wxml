<!-- pages/publish/publish.wxml - 发帖页（强制绑猫）-->
<view class="page {{isDarkMode ? 'dark' : ''}}" wx:if="{{!previewMode}}">

  <!-- 顶部标题 -->
  <view class="header">
    <text class="title">📸 发布帖子</text>
    <text class="subtitle">发帖必须绑定一只猫咪</text>
  </view>

  <!-- 图片上传区域 -->
  <view class="section">
    <!-- 内容区块：承载当前页面的表单或展示内容。 -->
    <view class="section-label">照片 <text class="required">*</text></view>
    <!-- 图片区块：展示图片、轮播或上传入口。 -->
    <view class="image-grid">
      <view class="img-item" wx:for="{{images}}" wx:key="index">
        <image class="preview-img" src="{{item}}" mode="aspectFill" />
        <view class="del-btn" bindtap="deleteImage" data-index="{{index}}">✕</view>
      </view>
      <view class="img-add" bindtap="chooseImage" wx:if="{{images.length < 9}}">
        <text class="add-icon">+</text>
        <text class="add-text">添加照片</text>
      </view>
    </view>
  </view>

  <!-- 帖子描述 -->
  <view class="section">
    <!-- 内容区块：承载当前页面的表单或展示内容。 -->
    <view class="section-label">描述 <text class="required">*</text></view>
    <textarea
      class="desc-input"
      placeholder="分享一下这只猫咪的故事..."
      value="{{content}}"
      bindinput="onContentInput"
      maxlength="500"
      auto-height
    />
    <text class="char-count">{{content.length}}/500</text>
  </view>

  <!-- 帖子分类 -->
  <view class="section">
    <!-- 内容区块：承载当前页面的表单或展示内容。 -->
    <view class="section-label">分类 <text class="required">*</text></view>
    <view class="category-grid">
      <view
        wx:for="{{categoryList}}"
        wx:key="value"
        class="category-tag {{category === item.value ? 'selected' : ''}}"
        bindtap="onCategoryTap"
        data-val="{{item.value}}"
      >{{item.label}}</view>
    </view>
  </view>

  <!-- 位置标记 -->
  <view class="section location-section">
    <!-- 内容区块：承载当前页面的表单或展示内容。 -->
    <view class="section-label">
      位置 <text class="optional">(可选)</text>
    </view>
    <!-- GPS 定位按钮 -->
    <view class="location-top">
      <button
        class="gps-btn {{locationLoading ? 'loading' : ''}}"
        bindtap="getGpsLocation"
        disabled="{{locationLoading}}"
      >
        {{locationLoading ? '定位中...' : '📍 获取 GPS 定位'}}
      </button>
      <view class="location-current" wx:if="{{locationLabel}}">
        <text class="location-label-text">{{locationLabel}}</text>
        <text class="location-clear" bindtap="clearLocation">清除</text>
      </view>
    </view>
    <!-- 校园地点标签 -->
    <view class="location-tags">
      <view
        wx:for="{{locationList}}"
        wx:key="index"
        class="location-tag {{selectedLocation === item ? 'selected' : ''}}"
        bindtap="onLocationTap"
        data-loc="{{item}}"
      >{{item}}</view>
    </view>
  </view>

  <!-- 绑猫区域 -->
  <view class="section bind-section">
    <!-- 内容区块：承载当前页面的表单或展示内容。 -->
    <view class="section-label">绑定猫咪 <text class="required">*</text> <text class="tip">（必须选择）</text></view>

    <!-- 未选择时：显示三种方式 -->
    <view class="bind-options" wx:if="{{!selectedCat && bindMode !== 'new_unknown'}}">
      <view class="bind-btn bind-btn-a" bindtap="selectBindMode" data-mode="pick_formal">
        <text class="bind-icon">📋</text>
        <view class="bind-text-wrap">
          <text class="bind-title">绑定已有正式猫</text>
          <text class="bind-desc">从已建档的猫咪中选择</text>
        </view>
        <text class="bind-arrow">›</text>
      </view>
      <view class="bind-btn bind-btn-b" bindtap="selectBindMode" data-mode="pick_unknown">
        <text class="bind-icon">🔍</text>
        <view class="bind-text-wrap">
          <text class="bind-title">绑定已有未知猫</text>
          <text class="bind-desc">从未知代号猫中选择</text>
        </view>
        <text class="bind-arrow">›</text>
      </view>
      <view class="bind-btn bind-btn-c" bindtap="selectBindMode" data-mode="new_unknown">
        <text class="bind-icon">✨</text>
        <view class="bind-text-wrap">
          <text class="bind-title">新建未知代号猫</text>
          <text class="bind-desc">第一次见到，快速建档</text>
        </view>
        <text class="bind-arrow">›</text>
      </view>
    </view>

    <!-- 已选择正式猫/未知猫 -->
    <view class="selected-cat" wx:if="{{selectedCat}}">
      <view class="cat-preview-card">
        <image
          wx:if="{{selectedCat.coverImage}}"
          class="cat-avatar"
          src="{{selectedCat.coverImage}}"
          mode="aspectFill"
        />
        <view class="cat-avatar cat-avatar-placeholder" wx:else>🐱</view>
        <view class="cat-info">
          <text class="cat-name">{{selectedCat.fullName || selectedCat.codeName}}</text>
          <text class="cat-meta">{{selectedCat.catType === 'formal' ? '正式猫' : '未知猫'}} · {{selectedCat.appearance}}</text>
        </view>
      </view>
      <view class="re-select" bindtap="resetBind">重新选择</view>
    </view>

    <!-- 新建未知猫内联表单 -->
    <view class="new-unknown-form" wx:if="{{bindMode === 'new_unknown' && !selectedCat}}">
      <view class="form-row">
        <text class="form-label">代号 <text class="required">*</text></text>
        <input
          class="form-input"
          placeholder="如：小橘、流浪白、猫3号"
          value="{{newUnknownForm.codeName}}"
          bindinput="onCodeNameInput"
          maxlength="20"
        />
      </view>
      <view class="form-row">
        <text class="form-label">外貌 <text class="required">*</text></text>
        <view class="appearance-grid">
          <view
            wx:for="{{appearanceOptions}}"
            wx:key="index"
            class="appearance-tag {{newUnknownForm.appearance === item ? 'selected' : ''}}"
            bindtap="onAppearanceTap"
            data-val="{{item}}"
          >{{item}}</view>
        </view>
      </view>
      <view class="cancel-new" bindtap="resetBind">取消，重新选择</view>
    </view>
  </view>

  <!-- 提交按钮 -->
  <view class="submit-wrap">
    <button class="preview-btn" bindtap="showPreview">
      👁️ 预览效果
    </button>
  </view>

</view>

<!-- ========== 预览模式 ========== -->
<view class="preview-page {{isDarkMode ? 'dark' : ''}}" wx:if="{{previewMode}}">
  <!-- 预览头部 -->
  <view class="preview-header">
    <!-- 预览区域：模拟最终展示效果供用户确认。 -->
    <view class="preview-back" bindtap="goBackToEdit">
      <text>← 返回编辑</text>
    </view>
    <text class="preview-title">预览效果</text>
    <!-- 预览区域：模拟最终展示效果供用户确认。 -->
    <view class="preview-placeholder"></view>
  </view>

  <!-- 预览内容（模拟帖子详情页样式） -->
  <scroll-view class="preview-scroll" scroll-y>
    <!-- 预览区域：模拟最终展示效果供用户确认。 -->
    <view class="preview-content">
      <!-- 图片轮播 -->
      <swiper
        class="preview-swiper"
        indicator-dots="{{images.length > 1}}"
        autoplay="{{false}}"
        circular="{{true}}"
        indicator-color="rgba(255,255,255,0.5)"
        indicator-active-color="#FF9A6A"
      >
        <swiper-item wx:for="{{images}}" wx:key="index">
          <image
            class="swiper-img"
            src="{{item}}"
            mode="aspectFill"
            bindtap="onPreviewImage"
            data-index="{{index}}"
          />
        </swiper-item>
      </swiper>

      <!-- 作者预览：提前确认发布后的昵称和头像展示效果 -->
      <view class="preview-author-card">
        <image
          class="preview-author-avatar"
          src="{{currentUserInfo.avatarUrl || '/assets/images/default-avatar.png'}}"
          mode="aspectFill"
        />
        <view class="preview-author-info">
          <text class="preview-author-name">{{currentUserInfo.nickName || '匿名用户'}}</text>
          <text class="preview-author-meta">发布后首页和详情会显示这组资料</text>
        </view>
      </view>

      <!-- 猫咪信息卡片 -->
      <view class="preview-cat-card">
        <view class="preview-cat-avatar">
          <image
            wx:if="{{selectedCat.coverImage}}"
            class="cat-avatar-img"
            src="{{selectedCat.coverImage}}"
            mode="aspectFill"
          />
          <text wx:else class="cat-avatar-text">🐱</text>
        </view>
        <view class="preview-cat-info">
          <text class="preview-cat-name">{{selectedCat.fullName || selectedCat.codeName || newUnknownForm.codeName || '未知猫'}}</text>
          <text class="preview-cat-meta">{{selectedCat.appearance || newUnknownForm.appearance || '外貌未知'}}</text>
        </view>
      </view>

      <!-- 分类标签 -->
      <view class="preview-category">
        <text class="category-badge" wx:if="{{category}}">
          {{category === 'daily' ? '日常' : category === 'rescue' ? '救助' : category === 'neuter' ? '绝育' : category === 'adopt' ? '领养' : category === 'lost' ? '寻猫' : '其他'}}
        </text>
      </view>

      <!-- 内容 -->
      <view class="preview-text">
        <text>{{content}}</text>
      </view>

      <!-- 位置信息 -->
      <view class="preview-location" wx:if="{{locationLabel}}">
        <text class="preview-location-text">📍 {{locationLabel}}</text>
      </view>

      <!-- 提示 -->
      <view class="preview-tip">
        <text>📌 这是帖子发布后的预览效果，确认无误后点击下方按钮发布</text>
      </view>

      <!-- 预览模式下的位置编辑入口 -->
      <view class="preview-location-edit" bindtap="goBackToEdit">
        <text>编辑位置 ›</text>
      </view>
    </view>
  </scroll-view>

  <!-- 确认发布按钮 -->
  <view class="preview-footer">
    <button class="edit-again-btn" bindtap="goBackToEdit">
      继续编辑
    </button>
    <button
      class="confirm-publish-btn {{submitting ? 'disabled' : ''}}"
      bindtap="confirmPublish"
      disabled="{{submitting}}"
    >
      {{submitting ? '发布中...' : '确认发布'}}
    </button>
  </view>
</view>

<!-- 猫咪选择弹窗 -->
<view class="picker-mask" wx:if="{{showCatPicker}}" bindtap="closeCatPicker" />
<!-- 猫咪区域：展示猫咪资料、档案或绑定信息。 -->
<view class="cat-picker" wx:if="{{showCatPicker}}">
  <!-- 选择器区域：展示待选项并支持筛选。 -->
  <view class="picker-header">
    <text class="picker-title">{{catPickMode === 'formal' ? '选择正式猫咪' : '选择未知代号猫'}}</text>
    <text class="picker-close" bindtap="closeCatPicker">✕</text>
  </view>
  <!-- 选择器区域：展示待选项并支持筛选。 -->
  <view class="picker-search">
    <input
      class="search-input"
      placeholder="搜索猫咪名字/代号..."
      bindinput="onPickSearch"
      value="{{catPickKeyword}}"
    />
  </view>
  <!-- 选择器区域：展示待选项并支持筛选。 -->
  <scroll-view class="picker-list" scroll-y>
    <!-- 状态区域：反馈当前数据加载进度。 -->
    <view class="loading-tip" wx:if="{{catPickLoading}}">加载中...</view>
    <!-- 空状态区域：在暂无数据时给出提示信息。 -->
    <view class="empty-tip" wx:elif="{{catPickList.length === 0}}">暂无猫咪，快去创建吧</view>
    <view
      wx:for="{{catPickList}}"
      wx:key="_id"
      class="picker-item"
      bindtap="onPickCat"
      data-cat="{{item}}"
    >
      <image
        wx:if="{{item.coverImage}}"
        class="picker-avatar"
        src="{{item.coverImage}}"
        mode="aspectFill"
      />
      <view class="picker-avatar picker-avatar-empty" wx:else>🐱</view>
      <view class="picker-cat-info">
        <text class="picker-cat-name">{{item.fullName || item.codeName}}</text>
        <text class="picker-cat-meta">{{item.appearance}} · {{item.location || '地点未知'}}</text>
      </view>
      <text class="picker-cat-vote">{{item.totalVote || 0}}票</text>
    </view>
  </scroll-view>
</view>
