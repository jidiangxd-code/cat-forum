/* pages/promote-cat/promote-cat.wxss */
.page {
  background: #fff5eb;
  min-height: 100vh;
  padding-bottom: 120rpx;
}
/* 加载提示与状态反馈样式。 */
.loading-page {
  height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #999;
}

.current-cat {
  background: linear-gradient(135deg, #88bbff, #5588ee);
  padding: 28rpx 28rpx 20rpx;
}
.current-header {
  margin-bottom: 16rpx;
}
.current-label {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
}
.current-card {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 16rpx;
  padding: 20rpx;
}
.current-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  margin-right: 20rpx;
  overflow: hidden;
  flex-shrink: 0;
}
/* 头像容器与兜底展示样式。 */
.avatar-empty {
  background: rgba(255, 255, 255, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 52rpx;
  border-radius: 50%;
}
.current-info {
  flex: 1;
}
.current-code {
  display: block;
  font-size: 30rpx;
  font-weight: bold;
  color: #fff;
}
.current-appearance {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.85);
  margin-top: 4rpx;
}
.unknown-badge {
  display: inline-block;
  margin-top: 8rpx;
  background: rgba(255, 255, 255, 0.2);
  color: #fff;
  padding: 4rpx 14rpx;
  border-radius: 12rpx;
  font-size: 20rpx;
}
.arrow-down {
  text-align: center;
  margin-top: 16rpx;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.85);
}

/* 表单输入与字段布局样式。 */
.form {
  padding: 0 24rpx;
}
.form-group {
  background: #fff;
  border-radius: 16rpx;
  margin-top: 20rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.03);
}
.form-label {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
  display: block;
}
.required {
  color: #f44;
}
.optional {
  color: #bbb;
  font-weight: normal;
  font-size: 24rpx;
}
/* 表单输入与字段布局样式。 */
.form-input {
  width: 100%;
  background: #f8f8f8;
  border-radius: 10rpx;
  padding: 18rpx 20rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
  border: 1rpx solid #eee;
}
.form-hint {
  display: block;
  font-size: 22rpx;
  color: #999;
  margin-top: 8rpx;
}

/* 封面图与占位背景样式。 */
.cover-pick {
}
.cover-preview {
  width: 100%;
  height: 240rpx;
  border-radius: 12rpx;
  display: block;
}
.cover-empty {
  height: 160rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #999;
  border: 2rpx dashed #eee;
}

.btn-group {
  display: flex;
  gap: 16rpx;
}
.option-btn {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  border-radius: 12rpx;
  border: 2rpx solid #eee;
  font-size: 26rpx;
  color: #666;
  background: #fff;
}
.option-btn.selected {
  background: #ff9a6a;
  border-color: #ff9a6a;
  color: #fff;
  font-weight: bold;
}

.info-tip {
  display: flex;
  align-items: flex-start;
  gap: 10rpx;
  background: #fff9e6;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-top: 20rpx;
  border: 1rpx solid #ffe082;
}
.tip-icon {
  font-size: 28rpx;
  flex-shrink: 0;
}
.tip-text {
  font-size: 24rpx;
  color: #888;
  line-height: 1.6;
}

/* 提交按钮与底部提交区样式。 */
.submit-wrap {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 32rpx 40rpx;
  background: #fff;
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.06);
}
.submit-btn {
  width: 100%;
  height: 88rpx;
  border-radius: 44rpx;
  background: linear-gradient(135deg, #ff9a6a, #ff7043);
  color: #fff;
  font-size: 30rpx;
  font-weight: bold;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}
.submit-btn.disabled {
  background: #ccc;
}
