/* pages/promote-cat/promote-cat.wxss（已迁移到 CSS 变量）*/
.page { background: var(--color-bg); min-height: 100vh; padding-bottom: 120rpx; }
.loading-page {
  height: 100vh; display: flex; align-items: center; justify-content: center;
  font-size: 28rpx; color: var(--color-text-desc);
}

.current-cat {
  background: var(--primary-gradient);
  padding: 28rpx 28rpx 20rpx;
}
.current-header { margin-bottom: 16rpx; }
.current-label { font-size: 26rpx; color: rgba(255,255,255,0.85); }
.current-card {
  display: flex; align-items: center;
  background: rgba(255,255,255,0.2); border-radius: 16rpx; padding: 20rpx;
}
.current-avatar {
  width: 100rpx; height: 100rpx; border-radius: 50%; margin-right: 20rpx;
  overflow: hidden; flex-shrink: 0;
}
.avatar-empty {
  background: rgba(255,255,255,0.3); display: flex;
  align-items: center; justify-content: center; font-size: 52rpx;
  border-radius: 50%;
}
.current-info { flex: 1; }
.current-code { display: block; font-size: 30rpx; font-weight: bold; color: var(--color-text-white); }
.current-appearance { display: block; font-size: 24rpx; color: rgba(255,255,255,0.85); margin-top: 4rpx; }
.unknown-badge {
  display: inline-block; margin-top: 8rpx; background: rgba(255,255,255,0.2);
  color: var(--color-text-white); padding: 4rpx 14rpx; border-radius: 12rpx; font-size: 20rpx;
}
.arrow-down {
  text-align: center; margin-top: 16rpx; font-size: 24rpx; color: rgba(255,255,255,0.85);
}

.form { padding: 0 24rpx; }
.form-group {
  background: var(--color-bg-card); border-radius: 16rpx; margin-top: 20rpx;
  padding: 24rpx; box-shadow: var(--color-shadow-card);
}
.form-label { font-size: 28rpx; font-weight: bold; color: var(--color-text-primary); margin-bottom: 16rpx; display: block; }
.required { color: var(--color-text-red); }
.optional { color: var(--color-text-muted); font-weight: normal; font-size: 24rpx; }
.form-input {
  width: 100%; background: var(--color-bg-disabled); border-radius: 10rpx;
  padding: 18rpx 20rpx; font-size: 28rpx; color: var(--color-text-primary);
  box-sizing: border-box; border: 1rpx solid var(--color-border);
}
.form-hint { display: block; font-size: 22rpx; color: var(--color-text-desc); margin-top: 8rpx; }

.cover-pick {}
.cover-preview { width: 100%; height: 240rpx; border-radius: 12rpx; display: block; }
.cover-empty {
  height: 160rpx; background: var(--color-bg-disabled); border-radius: 12rpx;
  display: flex; align-items: center; justify-content: center;
  font-size: 28rpx; color: var(--color-text-desc); border: 2rpx dashed var(--color-border);
}

.btn-group { display: flex; gap: 16rpx; }
.option-btn {
  flex: 1; text-align: center; padding: 16rpx 0; border-radius: 12rpx;
  border: 2rpx solid var(--color-border); font-size: 26rpx;
  color: var(--color-text-secondary); background: var(--color-bg-card);
}
.option-btn.selected { background: var(--color-bg-btn-primary); border-color: var(--color-bg-btn-primary); color: var(--color-text-white); font-weight: bold; }

.info-tip {
  display: flex; align-items: flex-start; gap: 10rpx;
  background: var(--color-bg-tag); border-radius: 12rpx; padding: 20rpx;
  margin-top: 20rpx; border: 1rpx solid var(--color-border-accent);
}
.tip-icon { font-size: 28rpx; flex-shrink: 0; }
.tip-text { font-size: 24rpx; color: var(--color-text-secondary); line-height: 1.6; }

.submit-wrap {
  position: fixed; bottom: 0; left: 0; right: 0;
  padding: 20rpx 32rpx 40rpx; background: var(--color-bg-card);
  box-shadow: var(--color-shadow-modal);
}
.submit-btn {
  width: 100%; height: 88rpx; border-radius: 44rpx;
  background: var(--btn-primary-gradient);
  color: var(--color-text-white); font-size: 30rpx; font-weight: bold;
  border: none; display: flex; align-items: center; justify-content: center;
  box-shadow: var(--color-shadow-btn);
}
.submit-btn.disabled { background: var(--color-bg-disabled); box-shadow: none; }
