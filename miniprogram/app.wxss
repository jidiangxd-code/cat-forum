/* ==================== 通用工具类 ==================== */

page { --rpx: 1rpx; }

.container { padding: 20rpx; box-sizing: border-box; background-color: var(--color-bg); }

/* 页面标题 */
.page-title {
  font-size: 40rpx; font-weight: bold;
  color: var(--color-text-accent); text-align: center; padding: 30rpx 0;
}

/* 区块标题 */
.section-title {
  font-size: 32rpx; font-weight: bold;
  color: var(--color-text-accent);
  margin-bottom: 20rpx; padding-left: 16rpx;
  border-left: 6rpx solid var(--color-border-accent);
  background-color: var(--color-bg);
}

/* 卡片 */
.card {
  background-color: var(--color-bg-card);
  border-radius: 24rpx; padding: 24rpx;
  margin-bottom: 24rpx; box-shadow: var(--color-shadow-card);
}

/* 按钮 */
.btn-primary {
  background: var(--color-bg-btn-primary);
  color: var(--color-text-white);
  border: none; border-radius: 40rpx;
  padding: 20rpx 48rpx; font-size: 30rpx; font-weight: bold;
  text-align: center; box-shadow: var(--color-shadow-btn);
}
.btn-primary::after { border: none; }
.btn-primary.hover { opacity: 0.85; transform: scale(0.97); }

.btn-secondary {
  background-color: var(--color-bg-btn-secondary);
  color: var(--color-text-accent);
  border: 2rpx solid var(--color-border-accent);
  border-radius: 40rpx; padding: 18rpx 40rpx; font-size: 28rpx; text-align: center;
}
.btn-secondary::after { border: none; }

.btn-danger {
  background: var(--color-bg-btn-danger);
  color: var(--color-text-white);
  border: none; border-radius: 40rpx;
  padding: 20rpx 48rpx; font-size: 30rpx; text-align: center;
}
.btn-danger::after { border: none; }

/* 分割线 */
.divider { height: 2rpx; background: var(--color-bg-divider); margin: 24rpx 0; }

/* 标签 */
.tag {
  display: inline-block;
  background-color: var(--color-bg-tag);
  color: var(--color-text-tag);
  border-radius: 20rpx; padding: 6rpx 16rpx; font-size: 22rpx;
  margin-right: 12rpx; margin-bottom: 8rpx;
}
.tag-health {
  background-color: var(--color-bg-tag-health);
  color: var(--color-text-tag-health);
}

/* 输入框 */
.input {
  background-color: var(--color-bg-input);
  color: var(--color-text-primary);
  border: 2rpx solid var(--color-border);
  border-radius: 16rpx; padding: 20rpx 24rpx; font-size: 28rpx;
}
.input::after { border: none; }
.input:focus { border-color: var(--color-border-accent); outline: none; }

/* 空状态 */
.empty-state { text-align: center; padding: 80rpx 40rpx; color: var(--color-text-muted); }
.empty-state .icon { font-size: 100rpx; margin-bottom: 20rpx; }

/* 加载 */
.loading-tip { text-align: center; padding: 30rpx; color: var(--color-text-muted); font-size: 26rpx; }

/* 文字颜色 */
.text-danger { color: var(--color-text-red); }
.text-success { color: var(--color-text-success); }
.text-blue { color: var(--color-text-blue); }

/* 边框 */
.border { border: 1rpx solid var(--color-border); }
.border-bottom { border-bottom: 1rpx solid var(--color-border); }
.border-top { border-top: 1rpx solid var(--color-border); }

/* Flex */
.flex { display: flex; }
.flex-col { flex-direction: column; }
.flex-center { align-items: center; justify-content: center; }
.flex-between { align-items: center; justify-content: space-between; }
.flex-wrap { flex-wrap: wrap; }
.flex-shrink-0 { flex-shrink: 0; }
.flex-1 { flex: 1; }
.gap-8 { gap: 8rpx; }
.gap-12 { gap: 12rpx; }
.gap-16 { gap: 16rpx; }
.gap-24 { gap: 24rpx; }

