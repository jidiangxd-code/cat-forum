/* 全局样式 - 温暖可爱的猫咪主题 */

page {
  background-color: #FFF5EB;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC',
    'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
  color: #4A4A4A;
  font-size: 28rpx;
  line-height: 1.6;
}

/* 全局变量 */
.container {
  padding: 20rpx;
  box-sizing: border-box;
}

/* 标题样式 */
.page-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #FF8C42;
  text-align: center;
  padding: 30rpx 0;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #6B4226;
  margin-bottom: 20rpx;
  padding-left: 16rpx;
  border-left: 6rpx solid #FFB74D;
}

/* 卡片通用样式 */
.card {
  background-color: #ffffff;
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(255, 154, 106, 0.15);
}

/* 按钮通用样式 */
.btn-primary {
  background: linear-gradient(135deg, #FFB74D 0%, #FF8C42 100%);
  color: #ffffff;
  border: none;
  border-radius: 40rpx;
  padding: 20rpx 48rpx;
  font-size: 30rpx;
  font-weight: bold;
  text-align: center;
  box-shadow: 0 6rpx 16rpx rgba(255, 140, 66, 0.35);
}

.btn-primary:active {
  opacity: 0.85;
  transform: scale(0.97);
}

.btn-secondary {
  background-color: #FFF5EB;
  color: #FF8C42;
  border: 2rpx solid #FFB74D;
  border-radius: 40rpx;
  padding: 18rpx 40rpx;
  font-size: 28rpx;
  text-align: center;
}

/* 分割线 */
.divider {
  height: 2rpx;
  background: linear-gradient(to right, transparent, #FFE0CC, transparent);
  margin: 24rpx 0;
}

/* 标签样式 */
.tag {
  display: inline-block;
  background-color: #FFF0E0;
  color: #E67E22;
  border-radius: 20rpx;
  padding: 6rpx 16rpx;
  font-size: 22rpx;
  margin-right: 12rpx;
  margin-bottom: 8rpx;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 80rpx 40rpx;
  color: #CCCCCC;
}

.empty-state .icon {
  font-size: 100rpx;
  margin-bottom: 20rpx;
}

/* 加载提示 */
.loading-tip {
  text-align: center;
  padding: 30rpx;
  color: #999999;
  font-size: 26rpx;
}
